---
const { lang = "pt" } = Astro.props;
const pt = lang === "pt";

// Sequential pipeline order — each connects to the next
const services = [
  { svc: "web",     name: "Website",          accent: "#38bdf8", icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>` },
  { svc: "crm",     name: "CRM & Backoffice", accent: "#22d3ee", icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>` },
  { svc: "graphic", name: "Graphic Design",   accent: "#fb923c", icon: `<path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 5 5"/><circle cx="11" cy="11" r="2"/>` },
  { svc: "drone",   name: "Foto & Drone",     accent: "#fbbf24", icon: `<path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/><path d="M7 4l-3 3"/><path d="M17 4l3 3"/><path d="M7 20l-3 -3"/><path d="M17 20l3 -3"/><path d="M4 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M4 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>` },
  { svc: "social",  name: "Social Media",     accent: "#a78bfa", icon: `<path d="M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><line x1="15.18" y1="5.73" x2="8.82" y2="9.27"/><line x1="8.82" y1="14.73" x2="15.18" y2="18.27"/>` },
];

// Node x positions in the SVG viewBox (0 0 1100 380)
// Centered at y = 190
const xs = [110, 310, 550, 790, 990];
const Y  = 190;

// How far above node-center each skip level routes (clears card tops at ~Y-65)
// skip 1 = bridge over 1 node, skip 2 = bridge over 2, etc.
const topYs = [100, 60, 22, -10]; // indexed by (j - i - 1), i.e. skip count

// Pre-compute all 10 (i,j) path data — orthogonal routing for skips
const pairs: Array<{ key: string; d: string; color: string }> = [];
for (let i = 0; i < 5; i++) {
  for (let j = i + 1; j < 5; j++) {
    const skip = j - i - 1; // 0 = adjacent nodes
    const d = skip === 0
      // Adjacent: straight horizontal line
      ? `M ${xs[i]} ${Y} L ${xs[j]} ${Y}`
      // Skip: up → right → down  (⊓ shape)
      : `M ${xs[i]} ${Y} L ${xs[i]} ${topYs[skip - 1]} L ${xs[j]} ${topYs[skip - 1]} L ${xs[j]} ${Y}`;
    pairs.push({ key: `${i}-${j}`, d, color: services[i].accent });
  }
}

// CSS left positions matching SVG x / 1100
const cssLefts = xs.map(x => `${(x / 1100 * 100).toFixed(2)}%`);
---

<section class="bundle-section" id="bundle">
  <div class="container">

    <div class="bundle-header" data-reveal>
      <span class="bundle-eyebrow">{pt ? "Pacote Sueste" : "Sueste Bundle"}</span>
      <h2>{pt ? "Ecossistema Digital" : "Digital Ecosystem"}</h2>
      <p>
        {pt
          ? "Cada serviço faz parte de uma cadeia. Desative um — os restantes reconectam-se automaticamente."
          : "Each service is part of a chain. Deactivate one — the rest reconnect automatically."}
      </p>
    </div>

    <!-- Desktop visualization -->
    <div class="bundle-stage" id="bundle-stage">

      <svg class="bundle-svg" viewBox="0 0 1100 380" preserveAspectRatio="xMidYMid meet" aria-hidden="true" style="overflow:visible">
        <defs>
          <filter id="pglow" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur stdDeviation="3" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          {pairs.map(p => (
            <linearGradient id={`grad-${p.key}`} gradientUnits="userSpaceOnUse"
              x1={xs[parseInt(p.key.split('-')[0])]} y1="0"
              x2={xs[parseInt(p.key.split('-')[1])]} y2="0">
              <stop offset="0%"   stop-color={services[parseInt(p.key.split('-')[0])].accent}/>
              <stop offset="100%" stop-color={services[parseInt(p.key.split('-')[1])].accent}/>
            </linearGradient>
          ))}
        </defs>

        <!-- Glow halos behind each connection -->
        {pairs.map(p => (
          <path
            class="conn-glow"
            data-conn={p.key}
            d={p.d}
            stroke={`url(#grad-${p.key})`}
            stroke-width="10"
            fill="none"
            opacity="0.07"
          />
        ))}

        <!-- Crisp connection lines -->
        {pairs.map(p => (
          <path
            id={`conn-${p.key}`}
            class="conn-line"
            data-conn={p.key}
            d={p.d}
            stroke={`url(#grad-${p.key})`}
            stroke-width="1.4"
            fill="none"
          />
        ))}

        <!-- Particles (2 per connection, staggered) -->
        {pairs.map((p, pi) => [
          <circle class="conn-particle" data-conn={p.key} r="3.5"
            fill={p.color} filter="url(#pglow)" opacity="1">
            <animateMotion id={`pm-${p.key}-a`} dur="2s" repeatCount="indefinite" begin={`${-(pi * 0.31) % 2}s`}>
              <mpath href={`#conn-${p.key}`}/>
            </animateMotion>
          </circle>,
          <circle class="conn-particle" data-conn={p.key} r="2"
            fill={p.color} opacity="0.45">
            <animateMotion dur="2s" repeatCount="indefinite" begin={`${-(pi * 0.31 + 1.0) % 2}s`}>
              <mpath href={`#conn-${p.key}`}/>
            </animateMotion>
          </circle>,
        ])}

        <!-- Node connector dots (small circles at each node position) -->
        {services.map((s, i) => (
          <circle class="node-dot-svg" data-idx={i} cx={xs[i]} cy={Y} r="5"
            fill={s.accent} opacity="0.7"/>
        ))}
      </svg>

      <!-- Service node cards -->
      {services.map((s, i) => (
        <button
          class="svc-node active"
          data-svc={s.svc}
          data-idx={String(i)}
          aria-pressed="true"
          style={`left:${cssLefts[i]};top:50%;--accent:${s.accent}`}
        >
          <span class="node-accent-line"></span>
          <span class="node-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
              set:html={s.icon}/>
          </span>
          <span class="node-name">{s.name}</span>
          <span class="node-toggle-pill"><span class="toggle-thumb"></span></span>
        </button>
      ))}
    </div>

    <!-- Active pills + CTA -->
    <div class="bundle-footer" data-reveal>
      <div class="bundle-pills" id="bundle-pills">
        {services.map(s => (
          <span class="bpill active" data-svc={s.svc} style={`--c:${s.accent}`}>{s.name}</span>
        ))}
      </div>
      <a href={pt ? "/orcamento" : "/en/quote"} class="bundle-cta-btn">
        {pt ? "Pedir Orçamento Personalizado" : "Request Custom Quote"}
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>
    </div>

    <!-- Mobile: vertical toggle list -->
    <div class="bundle-mobile">
      <div class="mobile-list">
        {services.map(s => (
          <button class="msvc-row active" data-svc={s.svc} style={`--c:${s.accent}`}>
            <span class="msvc-dot"></span>
            <span class="msvc-name">{s.name}</span>
            <span class="msvc-pill"><span class="mpill-thumb"></span></span>
          </button>
        ))}
      </div>
      <a href={pt ? "/orcamento" : "/en/quote"} class="bundle-cta-btn" style="margin-top:2rem;align-self:flex-start">
        {pt ? "Pedir Orçamento" : "Request Quote"}
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .bundle-section { padding: 8rem 0; }

  /* ── HEADER ─────────────────────────── */
  .bundle-header { max-width: 620px; margin-bottom: 4rem; }

  .bundle-eyebrow {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(56,189,248,0.07);
    border: 1px solid rgba(56,189,248,0.2);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #38bdf8;
    margin-bottom: 1.5rem;
  }

  .bundle-header h2 {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bundle-header p { font-size: 1.1rem; color: #71717a; line-height: 1.65; }

  /* ── STAGE ──────────────────────────── */
  .bundle-stage {
    position: relative;
    width: 100%;
    height: 420px;
    margin-bottom: 3rem;
    user-select: none;
  }

  .bundle-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Connections animate via JS-set stroke-dashoffset */
  .conn-line,
  .conn-glow {
    transition: stroke-dashoffset 0.55s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.4s ease;
  }

  .conn-particle { transition: opacity 0.3s ease; }

  /* Node connector dots */
  .node-dot-svg { transition: opacity 0.35s ease, r 0.3s ease; }

  /* ── SERVICE NODES ──────────────────── */
  .svc-node {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 148px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
    padding: 1rem 1.1rem 0.85rem;
    background: rgba(8, 10, 20, 0.9);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    backdrop-filter: blur(20px);
    cursor: grab;
    text-align: left;
    overflow: hidden;
    z-index: 20;
    transition:
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      opacity 0.35s ease,
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .svc-node::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: radial-gradient(circle at 30% 30%,
      color-mix(in srgb, var(--accent) 12%, transparent), transparent 70%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .svc-node.active {
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    box-shadow: 0 0 20px -6px var(--accent);
  }

  .svc-node.active::before { opacity: 1; }

  /* Solo state: last remaining active node */
  .svc-node.solo {
    border-color: var(--accent) !important;
    box-shadow: 0 0 40px -4px var(--accent), 0 0 80px -20px var(--accent) !important;
    animation: solo-pulse 2s ease-in-out infinite;
  }

  .svc-node.solo::before { opacity: 1; background: radial-gradient(circle at 40% 40%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 65%) !important; }

  @keyframes solo-pulse {
    0%, 100% { box-shadow: 0 0 40px -4px var(--accent), 0 0 80px -20px var(--accent); }
    50%       { box-shadow: 0 0 55px 2px var(--accent), 0 0 100px -10px var(--accent); }
  }

  .svc-node:not(.active) {
    opacity: 0.28;
    border-color: rgba(255,255,255,0.04);
    box-shadow: none;
  }

  .svc-node:hover { transform: translate(-50%, -50%) scale(1.05); }

  .svc-node.is-dragging {
    cursor: grabbing !important;
    box-shadow: 0 20px 50px -8px var(--accent), 0 0 80px -20px var(--accent) !important;
    border-color: var(--accent) !important;
    opacity: 0.92;
    scale: 1.06;
  }

  .node-accent-line {
    position: absolute;
    left: 0; top: 18%; bottom: 18%;
    width: 2px;
    border-radius: 2px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .svc-node.active .node-accent-line { opacity: 1; }

  .node-icon {
    width: 24px; height: 24px;
    color: var(--accent);
    transition: color 0.3s ease;
    flex-shrink: 0;
  }

  .svc-node:not(.active) .node-icon { color: #3f3f46; }

  .node-name {
    font-size: 0.76rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    transition: color 0.35s ease;
  }

  .svc-node:not(.active) .node-name { color: #3f3f46; }

  /* Toggle pill */
  .node-toggle-pill {
    align-self: flex-end;
    width: 28px; height: 15px;
    border-radius: 99px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
    flex-shrink: 0;
    transition: background 0.3s, border-color 0.3s;
  }

  .svc-node.active .node-toggle-pill {
    background: color-mix(in srgb, var(--accent) 28%, transparent);
    border-color: var(--accent);
  }

  .toggle-thumb {
    position: absolute;
    top: 2px; left: 2px;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: #3f3f46;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s;
  }

  .svc-node.active .toggle-thumb {
    transform: translateX(13px);
    background: var(--accent);
  }

  /* ── FOOTER ─────────────────────────── */
  .bundle-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .bundle-pills { display: flex; gap: 0.55rem; flex-wrap: wrap; }

  .bpill {
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.07);
    color: #52525b;
    background: transparent;
    transition: all 0.35s ease;
    cursor: pointer;
  }

  .bpill.active {
    border-color: color-mix(in srgb, var(--c) 40%, transparent);
    color: var(--c);
    background: color-mix(in srgb, var(--c) 8%, transparent);
  }

  .bundle-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.3s, transform 0.3s;
  }

  .bundle-cta-btn:hover { opacity: 0.88; transform: translateY(-2px); }

  /* ── MOBILE ─────────────────────────── */
  .bundle-mobile { display: none; }

  @media (max-width: 1024px) {
    .bundle-stage  { display: none; }
    .bundle-footer { display: none; }
    .bundle-mobile { display: flex; flex-direction: column; }
  }

  .mobile-list { display: flex; flex-direction: column; gap: 0.7rem; }

  .msvc-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 14px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    cursor: pointer;
    text-align: left;
    transition: all 0.3s ease;
  }

  .msvc-row.active {
    border-color: color-mix(in srgb, var(--c) 35%, transparent);
    background: color-mix(in srgb, var(--c) 5%, transparent);
  }

  .msvc-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: #3f3f46;
    flex-shrink: 0;
    transition: background 0.3s;
  }

  .msvc-row.active .msvc-dot { background: var(--c); }

  .msvc-name {
    flex: 1;
    font-size: 0.95rem;
    font-weight: 600;
    color: #52525b;
    transition: color 0.3s;
  }

  .msvc-row.active .msvc-name { color: #fff; }

  .msvc-pill {
    width: 36px; height: 20px;
    border-radius: 99px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    position: relative;
    flex-shrink: 0;
    transition: background 0.3s, border-color 0.3s;
  }

  .msvc-row.active .msvc-pill {
    background: color-mix(in srgb, var(--c) 25%, transparent);
    border-color: var(--c);
  }

  .mpill-thumb {
    position: absolute;
    top: 3px; left: 3px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #3f3f46;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s;
  }

  .msvc-row.active .mpill-thumb {
    transform: translateX(16px);
    background: var(--c);
  }
</style>

<script>
  const SVC_INIT = ['web', 'crm', 'graphic', 'drone', 'social'];
  // CSS left% for each slot — mirrors xs=[110,310,550,790,990] / 1100 * 100
  const SLOT_PCT = [10, 28.18, 50, 71.82, 90];

  let svcOrder = [...SVC_INIT];
  let activeMap: Record<string, boolean> = Object.fromEntries(SVC_INIT.map(s => [s, true]));

  // ── Drag state ──────────────────────────────────────────────────────────────
  let drag: {
    svc: string; el: HTMLElement;
    stageW: number; startX: number; origLeft: number;
    tempOrder: string[]; moved: boolean;
  } | null = null;

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function getCard(svc: string) {
    return document.querySelector<HTMLElement>(`.svc-node[data-svc="${svc}"]`);
  }

  function getActivePairs() {
    const ai = svcOrder.map((s, i) => activeMap[s] ? i : -1).filter(i => i >= 0);
    const pairs: [number, number][] = [];
    for (let k = 0; k < ai.length - 1; k++) pairs.push([ai[k], ai[k + 1]]);
    return pairs;
  }

  function applyConnections() {
    const vis = new Set(getActivePairs().map(([i, j]) => `${i}-${j}`));
    document.querySelectorAll<SVGPathElement>('.conn-line, .conn-glow').forEach(el => {
      const key = el.dataset.conn!;
      const len = (el as any)._len as number;
      if (!len) return;
      el.style.strokeDashoffset = vis.has(key) ? '0' : String(len);
    });
    document.querySelectorAll<SVGElement>('.conn-particle').forEach(el => {
      el.style.opacity = vis.has(el.dataset.conn!) ? '1' : '0';
    });
    // SVG slot dots opacity mirrors which slot's service is active
    svcOrder.forEach((svc, slot) => {
      const dot = document.querySelector<SVGElement>(`.node-dot-svg[data-idx="${slot}"]`);
      if (dot) dot.style.opacity = activeMap[svc] ? '0.7' : '0.15';
    });
  }

  function initPaths() {
    document.querySelectorAll<SVGPathElement>('.conn-line, .conn-glow').forEach(el => {
      try {
        const len = el.getTotalLength();
        (el as any)._len = len;
        el.style.strokeDasharray = String(len);
        el.style.strokeDashoffset = String(len);
      } catch (_) {}
    });
    requestAnimationFrame(() => applyConnections());
  }

  function updateCta() {
    const bundle = svcOrder.filter(s => activeMap[s]).join(',');
    const isEn = document.documentElement.lang === 'en';
    const href = `${isEn ? '/en/quote' : '/orcamento'}?bundle=${bundle}`;
    document.querySelectorAll<HTMLAnchorElement>('.bundle-cta-btn').forEach(btn => btn.href = href);
  }

  function applySlotPositions(skipSvc?: string) {
    svcOrder.forEach((svc, slot) => {
      if (svc === skipSvc) return;
      const el = getCard(svc);
      if (!el) return;
      el.style.left = `${SLOT_PCT[slot]}%`;
    });
  }

  // ── Toggle ───────────────────────────────────────────────────────────────────
  function toggleSvc(svc: string) {
    const cnt = Object.values(activeMap).filter(Boolean).length;
    if (activeMap[svc] && cnt <= 1) return;
    activeMap[svc] = !activeMap[svc];
    const now = activeMap[svc];

    document.querySelectorAll<HTMLElement>(`.svc-node[data-svc="${svc}"], .msvc-row[data-svc="${svc}"]`)
      .forEach(el => { el.classList.toggle('active', now); el.setAttribute('aria-pressed', String(now)); });

    const newCnt = Object.values(activeMap).filter(Boolean).length;
    document.querySelectorAll<HTMLElement>('.svc-node').forEach(el => {
      el.classList.toggle('solo', newCnt === 1 && !!activeMap[el.dataset.svc!]);
    });
    document.querySelectorAll<HTMLElement>('.bpill[data-svc]').forEach(el => {
      if (el.dataset.svc === svc) el.classList.toggle('active', now);
    });

    applyConnections();
    updateCta();
  }

  // ── Drag logic ───────────────────────────────────────────────────────────────
  function onDragStart(clientX: number, card: HTMLElement) {
    const stage = document.getElementById('bundle-stage');
    if (!stage) return;
    const svc = card.dataset.svc!;
    const slot = svcOrder.indexOf(svc);
    drag = {
      svc, el: card,
      stageW: stage.getBoundingClientRect().width,
      startX: clientX,
      origLeft: SLOT_PCT[slot],
      tempOrder: [...svcOrder],
      moved: false,
    };
    card.style.transition = 'none';
    card.style.zIndex = '30';
  }

  function onDragMove(clientX: number) {
    if (!drag) return;
    const dx = clientX - drag.startX;
    if (!drag.moved && Math.abs(dx) < 5) return;

    if (!drag.moved) {
      drag.moved = true;
      drag.el.classList.add('is-dragging');
      document.body.style.cursor = 'grabbing';
    }

    const newLeft = drag.origLeft + (dx / drag.stageW) * 100;
    drag.el.style.left = `${newLeft}%`;

    // Snap target: nearest slot by distance
    let nearSlot = 0, minDist = Infinity;
    SLOT_PCT.forEach((pct, i) => {
      const d = Math.abs(newLeft - pct);
      if (d < minDist) { minDist = d; nearSlot = i; }
    });

    const curSlot = drag.tempOrder.indexOf(drag.svc);
    if (nearSlot !== curSlot) {
      drag.tempOrder.splice(curSlot, 1);
      drag.tempOrder.splice(nearSlot, 0, drag.svc);
      // Slide other cards to their new slots
      drag.tempOrder.forEach((svc, slot) => {
        if (svc === drag!.svc) return;
        const el = getCard(svc);
        if (!el) return;
        el.style.transition = 'left 0.22s cubic-bezier(0.34, 1.56, 0.64, 1)';
        el.style.left = `${SLOT_PCT[slot]}%`;
      });
    }
  }

  function onDragEnd() {
    if (!drag) return;
    const { svc, el, tempOrder, moved } = drag;
    drag = null;
    document.body.style.cursor = '';
    el.classList.remove('is-dragging');

    if (!moved) {
      // Treated as a click — toggle
      el.style.transition = '';
      el.style.zIndex = '';
      toggleSvc(svc);
      return;
    }

    // Commit new order and snap card to final slot
    svcOrder = [...tempOrder];
    const finalSlot = svcOrder.indexOf(svc);
    el.style.transition = 'left 0.22s cubic-bezier(0.34, 1.56, 0.64, 1)';
    el.style.left = `${SLOT_PCT[finalSlot]}%`;
    el.style.zIndex = '';

    applyConnections();
    updateCta();

    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('.svc-node').forEach(c => { c.style.transition = ''; });
    }, 250);
  }

  // Global listeners (defined outside init so references are stable for remove)
  function _onMouseMove(e: MouseEvent) { onDragMove(e.clientX); }
  function _onMouseUp() { onDragEnd(); }

  // ── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    svcOrder = [...SVC_INIT];
    activeMap = Object.fromEntries(SVC_INIT.map(s => [s, true]));
    initPaths();
    applySlotPositions();
    updateCta();

    // Re-register global drag listeners (clean up any previous)
    document.removeEventListener('mousemove', _onMouseMove);
    document.removeEventListener('mouseup', _onMouseUp);
    document.addEventListener('mousemove', _onMouseMove);
    document.addEventListener('mouseup', _onMouseUp);

    // Desktop node cards: drag (mousedown) + touch
    document.querySelectorAll<HTMLElement>('.svc-node').forEach(card => {
      const fresh = card.cloneNode(true) as HTMLElement;
      card.parentNode?.replaceChild(fresh, card);

      fresh.addEventListener('mousedown', e => {
        e.preventDefault(); // prevent text-selection drag
        onDragStart(e.clientX, fresh);
      });
      fresh.addEventListener('touchstart', e => {
        onDragStart(e.touches[0].clientX, fresh);
      }, { passive: true });
      fresh.addEventListener('touchmove', e => {
        e.preventDefault();
        onDragMove(e.touches[0].clientX);
      }, { passive: false });
      fresh.addEventListener('touchend', onDragEnd);
    });

    // Mobile rows: click-only toggle
    document.querySelectorAll<HTMLElement>('.msvc-row').forEach(row => {
      const fresh = row.cloneNode(true) as HTMLElement;
      row.parentNode?.replaceChild(fresh, row);
      fresh.addEventListener('click', () => toggleSvc(fresh.dataset.svc!));
    });

    // Pills: click-only toggle
    document.querySelectorAll<HTMLElement>('.bpill').forEach(pill => {
      const fresh = pill.cloneNode(true) as HTMLElement;
      pill.parentNode?.replaceChild(fresh, pill);
      fresh.addEventListener('click', () => toggleSvc(fresh.dataset.svc!));
    });
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
