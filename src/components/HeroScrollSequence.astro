---

---

<div class="hero-scroll-container">
  <div class="sticky-pin">
    <canvas id="hero-canvas"></canvas>
    <img
      src="/images/hero-video/sueste-hero-animation001.webp"
      class="mobile-hero-bg"
      alt=""
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-gradient-overlay"></div>
    <div class="hero-overlay">
      <!-- Local decorative blobs for better visibility -->
      <div class="hero-bg-blob"></div>
      <slot />
    </div>
  </div>
</div>

<style>
  .hero-scroll-container {
    height: 400vh; /* Determines how long the user scrolls to see the whole video */
    position: relative;
    background-color: transparent;
  }

  .sticky-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #hero-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    opacity: 0.95; /* Dim the video slightly to make text pop */
  }

  /* Add a dark gradient overlay so text is always readable */
  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.6) 0%,
      rgba(5, 5, 5, 0) 25%,
      rgba(5, 5, 5, 0) 75%,
      rgba(5, 5, 5, 0) 100%
    );
  }

  .hero-overlay {
    position: relative;
    z-index: 10;
    text-align: center;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-bg-blob {
    position: absolute;
    width: 80vw;
    height: 80vw;
    background: radial-gradient(
      circle,
      rgba(56, 189, 248, 0.3) 0%,
      transparent 70%
    );
    filter: blur(100px);
    z-index: -1;
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* Let GSAP handle the reveal, hide standard data-reveal starting state */
  .hero-overlay[data-reveal] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-container {
      height: 100vh;
    }
  }

  /* Mobile: static hero, no scroll sequence */
  .mobile-hero-bg {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-scroll-container {
      height: 100vh;
    }
    #hero-canvas {
      display: none;
    }
    .mobile-hero-bg {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: 1;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const isDesktop = window.matchMedia("(min-width: 769px)").matches;
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!isDesktop || reducedMotion) {
    // Mobile / reduced motion: make hero text immediately visible, no animation
    const heroContentAnim = document.querySelector(".hero-content-anim") as HTMLElement;
    if (heroContentAnim) {
      heroContentAnim.style.opacity = "1";
      heroContentAnim.style.transform = "none";
      heroContentAnim.style.filter = "none";
    }
  } else {
    // Desktop only: run full canvas scroll animation
    const frameCount = 500;
    const currentFrame = (index: number) =>
      `/images/hero-video/sueste-hero-animation${(index + 1)
        .toString()
        .padStart(3, "0")}.webp`;

    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
    const context = canvas.getContext("2d");

    canvas.width = 1920;
    canvas.height = 1080;

    const images: (HTMLImageElement | null)[] = new Array(frameCount).fill(null);
    const imageSeq = { frame: 0 };

    // Load frame 0 immediately (LCP)
    const firstImg = new Image();
    firstImg.src = currentFrame(0);
    firstImg.onload = () => {
      images[0] = firstImg;
      render();
    };
    images[0] = firstImg;

    // Progressive load: remaining frames via requestIdleCallback
    let nextToLoad = 1;
    function loadNextBatch() {
      const batchSize = 10;
      const end = Math.min(nextToLoad + batchSize, frameCount);
      for (let i = nextToLoad; i < end; i++) {
        const img = new Image();
        img.src = currentFrame(i);
        images[i] = img;
      }
      nextToLoad = end;
      if (nextToLoad < frameCount) {
        requestIdleCallback(loadNextBatch);
      }
    }
    requestIdleCallback(loadNextBatch);

    // Hero text animation
    const heroContentAnim = document.querySelector(".hero-content-anim");
    gsap.set(heroContentAnim, { opacity: 0, y: 80, scale: 0.9, filter: "blur(10px)" });

    gsap
      .timeline({
        scrollTrigger: {
          trigger: ".hero-scroll-container",
          start: "top top",
          end: "bottom bottom",
          scrub: 1,
        },
      })
      .to(heroContentAnim, { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: 0.15, ease: "power2.out" })
      .to(heroContentAnim, { opacity: 1, duration: 0.65 })
      .to(heroContentAnim, { opacity: 0, y: -150, scale: 1.05, filter: "blur(15px)", duration: 0.2, ease: "power2.in" });

    gsap.to(imageSeq, {
      frame: frameCount - 1,
      snap: "frame",
      ease: "none",
      scrollTrigger: {
        trigger: ".hero-scroll-container",
        start: "top top",
        end: "bottom bottom",
        scrub: 1.5,
      },
      onUpdate: render,
    });

    function render() {
      const img = images[imageSeq.frame];
      if (!img || !img.complete || !img.naturalWidth) return;

      const hRatio = canvas.width / img.width;
      const vRatio = canvas.height / img.height;
      const ratio = Math.max(hRatio, vRatio);
      const centerShift_x = (canvas.width - img.width * ratio) / 2;
      const centerShift_y = (canvas.height - img.height * ratio) / 2;

      context?.clearRect(0, 0, canvas.width, canvas.height);
      context?.drawImage(img, 0, 0, img.width, img.height, centerShift_x, centerShift_y, img.width * ratio, img.height * ratio);
    }
  }
</script>
