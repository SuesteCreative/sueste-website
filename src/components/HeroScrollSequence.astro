---

---

<div class="hero-scroll-container">
  <div class="sticky-pin">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-gradient-overlay"></div>
    <div class="hero-overlay">
      <!-- Local decorative blobs for better visibility -->
      <div class="hero-bg-blob"></div>
      <slot />
    </div>
  </div>
</div>

<style>
  .hero-scroll-container {
    height: 400vh; /* Determines how long the user scrolls to see the whole video */
    position: relative;
    background-color: transparent;
  }

  .sticky-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #hero-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    opacity: 0.95; /* Dim the video slightly to make text pop */
  }

  /* Add a dark gradient overlay so text is always readable */
  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.6) 0%,
      rgba(5, 5, 5, 0) 25%,
      rgba(5, 5, 5, 0) 75%,
      rgba(5, 5, 5, 0) 100%
    );
  }

  .hero-overlay {
    position: relative;
    z-index: 10;
    text-align: center;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-bg-blob {
    position: absolute;
    width: 80vw;
    height: 80vw;
    background: radial-gradient(
      circle,
      rgba(56, 189, 248, 0.3) 0%,
      transparent 70%
    );
    filter: blur(100px);
    z-index: -1;
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* Let GSAP handle the reveal, hide standard data-reveal starting state */
  .hero-overlay[data-reveal] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-container {
      height: 100vh;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Define total frames generated
  const frameCount = 500;
  const currentFrame = (index: number) =>
    `/images/hero-video/sueste-hero-animation${(index + 1)
      .toString()
      .padStart(3, "0")}.webp`;

  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;

  if (
    canvas &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    const context = canvas.getContext("2d");

    // Set internal resolution of the canvas (e.g. 1920x1080)
    canvas.width = 1920;
    canvas.height = 1080;

    const images: HTMLImageElement[] = [];
    const imageSeq = {
      frame: 0,
    };

    // Preload all frames
    for (let i = 0; i < frameCount; i++) {
      const img = new Image();
      img.src = currentFrame(i);
      images.push(img);
    }

    // Render the very first frame quickly once loaded
    images[0].onload = render;

    // The hero content fading logic
    const heroContentAnim = document.querySelector(".hero-content-anim");

    // Start completely hidden
    gsap.set(heroContentAnim, {
      opacity: 0,
      y: 80,
      scale: 0.9,
      filter: "blur(10px)",
    });

    // Animate Hero Text revealing natively ON SCROLL, then hiding
    gsap
      .timeline({
        scrollTrigger: {
          trigger: ".hero-scroll-container",
          start: "top top", // Starts animating right as you scroll down from top
          end: "bottom bottom", // Sync this with the full video timeline length
          scrub: 1, // Smooth scrub
        },
      })
      .to(heroContentAnim, {
        opacity: 1,
        y: 0,
        scale: 1,
        filter: "blur(0px)",
        duration: 0.15,
        ease: "power2.out",
      }) // Reveal during early scroll
      .to(heroContentAnim, { opacity: 1, duration: 0.65 }) // Hold for a much longer time
      .to(heroContentAnim, {
        opacity: 0,
        y: -150,
        scale: 1.05,
        filter: "blur(15px)",
        duration: 0.2,
        ease: "power2.in",
      }); // Fade out towards the end of the scroll sequence

    // Create the ScrollTrigger tied to the timeline (the video)
    gsap.to(imageSeq, {
      frame: frameCount - 1,
      snap: "frame",
      ease: "none",
      scrollTrigger: {
        trigger: ".hero-scroll-container",
        start: "top top",
        end: "bottom bottom",
        scrub: 1.5, // 1.5 seconds smoothing (inertia)
      },
      onUpdate: render,
    });

    function render() {
      if (!images[imageSeq.frame]) return;

      // Calculate aspect ratios to maintain "cover" effect
      const hRatio = canvas.width / images[imageSeq.frame].width;
      const vRatio = canvas.height / images[imageSeq.frame].height;
      const ratio = Math.max(hRatio, vRatio);

      const centerShift_x =
        (canvas.width - images[imageSeq.frame].width * ratio) / 2;
      const centerShift_y =
        (canvas.height - images[imageSeq.frame].height * ratio) / 2;

      context?.clearRect(0, 0, canvas.width, canvas.height);
      context?.drawImage(
        images[imageSeq.frame],
        0,
        0,
        images[imageSeq.frame].width,
        images[imageSeq.frame].height,
        centerShift_x,
        centerShift_y,
        images[imageSeq.frame].width * ratio,
        images[imageSeq.frame].height * ratio,
      );
    }
  }
</script>
