---
const { lang = "pt" } = Astro.props;

const titlePt = "Sobre Nós";
const titleEn = "About Us";

const headlinePt =
    "Presenças digitais <span class='text-gradient'>que dominam.</span>";
const headlineEn =
    "Digital presences <span class='text-gradient'>that dominate.</span>";

const descPt1 =
    "A Sueste Creative Agency é o seu parceiro estratégico no mundo digital. Combinamos web design de alta performance, otimização SEO avançada e tecnologia de ponta para elevar a sua marca ao topo dos motores de busca e do mercado.";
const descEn1 =
    "Sueste Creative Agency is your strategic partner in the digital world. We combine high-performance web design, advanced SEO optimization, and cutting-edge technology to elevate your brand to the top of search engines and the market.";

const descPt2 =
    "Do desenvolvimento web inovador à gestão de social media e cinematografia com drones, garantimos que cada ponto de contacto da sua identidade visual seja excecional, comunicando autoridade e atraindo o seu público ideal.";
const descEn2 =
    "From innovative web development to social media management and drone cinematography, we ensure that every touchpoint of your visual identity is exceptional, communicating authority and attracting your ideal audience.";

const imageUrl =
    "https://images.unsplash.com/photo-1473968512647-3e447244af8f?q=80&w=2070&auto=format&fit=crop";
---

<section class="about-section" id="about" data-reveal>
    <div class="container">
        <div class="about-grid">
            <div class="about-content">
                <span class="section-badge" data-reveal
                    >{lang === "pt" ? titlePt : titleEn}</span
                >
                <h2
                    class="about-headline reveal-delay-1"
                    data-reveal
                    set:html={lang === "pt" ? headlinePt : headlineEn}
                >
                </h2>
                <div class="about-text-wrapper reveal-delay-2" data-reveal>
                    <p>{lang === "pt" ? descPt1 : descEn1}</p>
                    <p>{lang === "pt" ? descPt2 : descEn2}</p>
                </div>
                <div class="about-stats reveal-delay-3" data-reveal>
                    <div class="stat-item">
                        <span class="stat-number">50+</span>
                        <span class="stat-label"
                            >{
                                lang === "pt"
                                    ? "Projetos Lançados"
                                    : "Projects Launched"
                            }</span
                        >
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">10+</span>
                        <span class="stat-label"
                            >{
                                lang === "pt"
                                    ? "Marcas Elevadas"
                                    : "Brands Elevated"
                            }</span
                        >
                    </div>
                </div>
            </div>

            <div class="about-image-wrapper reveal-delay-2" data-reveal>
                <div class="image-glass-frame">
                    <img
                        src={imageUrl}
                        alt={lang === "pt" ? "Equipa Sueste" : "Sueste Team"}
                        loading="lazy"
                    />
                    <div class="image-overlay-gradient"></div>
                </div>
                <!-- Decorative blobs behind image -->
                <div class="decor-blob blob-1"></div>
                <div class="decor-blob blob-2"></div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-section {
        padding: 10rem 0;
        position: relative;
        overflow: hidden;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .section-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 2rem;
        backdrop-filter: blur(10px);
    }

    .about-headline {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 2rem;
        letter-spacing: -0.02em;
    }

    .text-gradient {
        background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .about-text-wrapper {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .about-text-wrapper p {
        font-size: 1.15rem;
        color: #a1a1aa;
        line-height: 1.6;
        font-weight: 300;
    }

    .about-stats {
        display: flex;
        gap: 3rem;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .stat-number {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1;
        color: #fff;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #71717a;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .about-image-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 500px;
    }

    .image-glass-frame {
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 500px;
        border-radius: 24px;
        overflow: hidden;
        z-index: 2;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        transform: perspective(1000px) rotateY(-5deg);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .about-image-wrapper:hover .image-glass-frame {
        transform: perspective(1000px) rotateY(0deg) scale(1.02);
    }

    .image-glass-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.6s ease;
    }

    .about-image-wrapper:hover .image-glass-frame img {
        transform: scale(1.05); /* Slight image zoom on hover */
    }

    .image-overlay-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(5, 5, 5, 0.1) 0%,
            rgba(37, 99, 235, 0.2) 100%
        );
        z-index: 3;
        mix-blend-mode: overlay;
        pointer-events: none;
    }

    .decor-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        z-index: 1;
        opacity: 0.5;
    }

    .blob-1 {
        width: 300px;
        height: 300px;
        background: #38bdf8;
        top: -50px;
        right: -50px;
    }

    .blob-2 {
        width: 250px;
        height: 250px;
        background: #2563eb;
        bottom: -50px;
        left: -50px;
    }

    @media (max-width: 1024px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .about-image-wrapper {
            min-height: 400px;
        }

        .image-glass-frame {
            min-height: 400px;
            transform: none;
        }

        .about-image-wrapper:hover .image-glass-frame {
            transform: none;
        }
    }

    @media (max-width: 768px) {
        .about-section {
            padding: 6rem 0;
        }

        .about-headline {
            font-size: 2.2rem;
        }

        .about-stats {
            gap: 1.5rem;
        }

        .stat-number {
            font-size: 2.5rem;
        }
    }
</style>
