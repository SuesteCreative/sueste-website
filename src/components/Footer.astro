---
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <a href="/" class="logo">
        <img src="/images/logo-white-vert.png" alt="Sueste Creative Logo" class="footer-logo-img" />
      </a>
      <p>{t('hero.subheadline')}</p>
    </div>
    
    <div class="footer-links">
      <div class="link-group">
        <h4>Sueste</h4>
        <a href={lang === 'pt' ? '/sobre' : '/en/about'}>{t('nav.about')}</a>
        <a href={lang === 'pt' ? '/servicos' : '/en/services'}>{t('nav.services')}</a>
        <a href={lang === 'pt' ? '/portfolio' : '/en/work'}>{t('nav.work')}</a>
      </div>
      <div class="link-group">
        <h4>Legal</h4>
        <a href={lang === 'pt' ? '/privacidade' : '/en/privacy'}>{t('footer.privacy')}</a>
        <a href={lang === 'pt' ? '/termos' : '/en/terms'}>{t('footer.terms')}</a>
      </div>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <p>&copy; {year} Sueste Creative. {t('footer.rights')}</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    padding: 4rem 0 2rem;
    margin-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  .footer-brand {
    max-width: 400px;
  }
  
  .footer-brand p {
    margin-top: 1rem;
    opacity: 0.6;
    font-size: 0.9rem;
  }
  
  .footer-links {
    display: flex;
    gap: 4rem;
  }
  
  .link-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .link-group h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
  }
  
  .link-group a {
    font-size: 0.9rem;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  
  .link-group a:hover {
    opacity: 1;
  }
  
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
    font-size: 0.8rem;
    opacity: 0.5;
  }
  
  .footer-logo-img {
    height: 80px;
    width: auto;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: 3rem;
    }
    .footer-links {
      gap: 2rem;
      flex-wrap: wrap;
    }
  }
</style>
