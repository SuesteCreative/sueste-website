---
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={lang === "pt" ? "/" : "/en/"} class="logo">
          <img
            src="/images/logo-white-hor.webp"
            alt="Sueste Creative Logo"
            class="footer-logo-img"
          />
        </a>
        <p class="brand-description">{t("hero.subheadline")}</p>
        <div class="footer-contact-info">
          <p>Lisboa, Portugal</p>
          <a href="tel:+351965494727" class="phone-link">+351 965 494 727</a>
          <a href="mailto:info@sueste-creative.pt" class="email-link"
            >info@sueste-creative.pt</a
          >
        </div>
      </div>

      <div class="footer-nav-columns">
        <div class="link-group">
          <h4>Sueste</h4>
          <ul class="footer-list">
            <li>
              <a href={lang === "pt" ? "/sobre" : "/en/about"}
                >{t("nav.about")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/servicos" : "/en/services"}
                >{t("nav.services")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/portfolio" : "/en/work"}
                >{t("nav.work")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/contacto" : "/en/contact"}
                >{t("nav.contact")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/orcamento" : "/en/quote"}
                >{t("nav.quote")}</a
              >
            </li>
          </ul>
        </div>

        <div class="link-group">
          <h4>Legal</h4>
          <ul class="footer-list">
            <li>
              <a href={lang === "pt" ? "/cookies" : "/en/cookies"}
                >{t("footer.cookies")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/termos" : "/en/terms"}
                >{t("footer.terms")}</a
              >
            </li>
            <li>
              <a href={lang === "pt" ? "/privacidade" : "/en/privacy"}
                >{t("footer.privacy")}</a
              >
            </li>
          </ul>
        </div>

        <div class="link-group">
          <h4>{t("footer.socials")}</h4>
          <div class="social-icons-footer">
            <a
              href="https://www.instagram.com/sueste.agency/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                ></rect><path
                  d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              <span>Instagram</span>
            </a>
            <a
              href="https://www.facebook.com/sueste.agency"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path>
              </svg>
              <span>Facebook</span>
            </a>
            <a
              href="https://linkedin.com/company/sueste-creative"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle>
              </svg>
              <span>LinkedIn</span>
            </a>
            <a
              href="https://www.tiktok.com"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
              </svg>
              <span>TikTok</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Sueste Creative. {t("footer.rights")}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: transparent;
    padding: 10rem 0 4rem;
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 3fr;
    gap: 6rem;
    margin-bottom: 6rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-logo-img {
    height: 120px;
    width: auto;
  }

  .brand-description {
    opacity: 0.8;
    font-size: 1.1rem;
    line-height: 1.4;
    max-width: 320px;
    font-weight: 500;
    white-space: pre-line;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-contact-info p,
  .footer-contact-info a {
    font-size: 0.9rem;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .footer-contact-info a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .footer-nav-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .link-group h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 2rem;
    color: var(--color-accent);
    font-weight: 800;
  }

  .footer-list {
    list-style: none !important;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer-list li {
    list-style: none !important;
    padding: 0;
    margin: 0;
  }

  .footer-list a {
    font-size: 1rem;
    opacity: 0.6;
    font-weight: 500;
    transition: all 0.3s ease;
    text-decoration: none;
    display: block;
  }

  .social-icons-footer {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    align-items: center;
    margin-top: 1rem;
    max-width: fit-content;
  }

  .social-pill {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem;
    border-radius: 50px;
    color: #fff;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
    white-space: nowrap;
    width: 46px;
    height: 46px;
    justify-content: center;
  }

  .social-pill span {
    opacity: 0;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-10px);
    width: 0;
  }

  .social-pill:hover {
    width: 140px;
    background: rgba(56, 189, 248, 0.1);
    border-color: #38bdf8;
    padding: 0 1.25rem;
    gap: 0.75rem;
    justify-content: flex-start;
  }

  .social-pill:hover span {
    opacity: 1;
    transform: translateX(0);
    width: auto;
  }

  .footer-list a:hover {
    opacity: 1;
    color: #fff;
    padding-left: 4px;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
    font-size: 0.85rem;
    opacity: 0.4;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .footer-nav-columns {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 3rem;
    }

    .brand-description {
      max-width: 100%;
    }
  }
</style>
