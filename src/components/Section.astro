---
interface Props {
  id?: string;
  className?: string;
  title?: string;
  subtitle?: string;
  dark?: boolean;
}

const { id, className, title, subtitle, dark = false } = Astro.props;
---

<section id={id} class:list={["section", { "section-dark": dark }, className]}>
  <div class="container">
    {
      (title || subtitle) && (
        <div class="section-header">
          {title && <h2>{title}</h2>}
          {subtitle && <p>{subtitle}</p>}
        </div>
      )
    }
    <slot />
  </div>
</section>

<style>
  .section {
    padding: 8rem 0;
  }

  .section-dark {
    background-color: transparent;
  }

  .section-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-header p {
    font-size: 1.1rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .section {
      padding: 5rem 0;
    }
    .section-header {
      margin-bottom: 3rem;
    }
    .section-header h2 {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
    }
  }
</style>
