---
interface Props {
  id?: string;
  className?: string;
  title?: string;
  subtitle?: string;
  dark?: boolean;
}

const { id, className, title, subtitle, dark = false } = Astro.props;
---

<section id={id} class:list={['section', { 'section-dark': dark }, className]}>
  <div class="container">
    {(title || subtitle) && (
      <div class="section-header">
        {title && <h2>{title}</h2>}
        {subtitle && <p>{subtitle}</p>}
      </div>
    )}
    <slot />
  </div>
</section>

<style>
  .section {
    padding: 8rem 0;
  }
  
  .section-dark {
    background-color: #080808;
  }
  
  .section-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }
  
  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  
  .section-header p {
    font-size: 1.1rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .section {
      padding: 4rem 0;
    }
    .section-header h2 {
      font-size: 2rem;
    }
  }
</style>
