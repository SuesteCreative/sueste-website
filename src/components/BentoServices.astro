---

<div class="bento-container" id="bento-services">
    <div class="bento-grid">
        {
            services.map((service, index) => (
                <div
                    class={`bento-card bento-${service.size} magnetic-card reveal-delay-${(index % 3) + 1}`}
                    data-reveal
                    data-accent={service.accent}
                    style={`--accent: ${service.accent};`}
                >
                    <div class="bento-glow" />
                    <div class="bento-icon-bg" set:html={service.iconBig} />
                    <div class="bento-content">
                        <div class="bento-label">
                            <span class="bento-icon-small" set:html={service.icon} />
                        </div>
                        <h3>{service.title}</h3>
                        <p>{lang === "pt" ? service.descPt : service.descEn}</p>
                    </div>
                </div>
            ))
        }
    </div>
</div>

<style>
    .bento-container {
        width: 100%;
        margin-top: 3rem;
    }

    .bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(2, minmax(280px, auto));
        gap: 1.5rem;
    }

    .bento-card {
        position: relative;
        border-radius: 24px;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        transition:
            transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275),
            border-color 0.4s ease,
            box-shadow 0.4s ease;
        will-change: transform;
        cursor: pointer;
    }

    /* Accent border glow on hover — was broken before (all stops were alpha 0) */
    .bento-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 24px;
        padding: 1px;
        background: linear-gradient(
            135deg,
            transparent 0%,
            var(--accent, #38bdf8) 50%,
            transparent 100%
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: 1;
        pointer-events: none;
    }

    .bento-card:hover::before {
        opacity: 1;
    }

    .bento-card:hover {
        box-shadow: 0 0 40px -10px var(--accent, #38bdf8);
        border-color: rgba(255, 255, 255, 0.12);
    }

    /* Grid Area Assignments */
    .bento-large {
        grid-column: span 2;
        grid-row: span 1;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            rgba(255, 255, 255, 0.01) 100%
        );
    }

    .bento-small {
        grid-column: span 1;
        grid-row: span 1;
    }

    .bento-medium {
        grid-column: span 2;
        grid-row: span 1;
    }

    /* Large decorative icon in background */
    .bento-icon-bg {
        position: absolute;
        bottom: -1rem;
        right: -1rem;
        width: 200px;
        height: 200px;
        color: var(--accent, #38bdf8);
        opacity: 0.05;
        pointer-events: none;
        z-index: 0;
        transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .bento-card:hover .bento-icon-bg {
        opacity: 0.1;
        transform: scale(1.08) rotate(-5deg);
    }

    /* Small icon label */
    .bento-label {
        margin-bottom: 1rem;
    }

    .bento-icon-small {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: color-mix(in srgb, var(--accent, #38bdf8) 15%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent, #38bdf8) 30%, transparent);
        color: var(--accent, #38bdf8);
        padding: 10px;
        transition: background 0.3s ease, transform 0.3s ease;
    }

    .bento-card:hover .bento-icon-small {
        background: color-mix(in srgb, var(--accent, #38bdf8) 25%, transparent);
        transform: scale(1.1);
    }

    /* Mouse-follow glow blob */
    .bento-glow {
        position: absolute;
        width: 350px;
        height: 350px;
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--accent, #38bdf8) 20%, transparent) 0%,
            transparent 70%
        );
        border-radius: 50%;
        top: -175px;
        left: -175px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
        transform: translate(var(--mouse-x, 0), var(--mouse-y, 0));
    }

    .bento-card:hover .bento-glow {
        opacity: 1;
    }

    .bento-content {
        position: relative;
        z-index: 2;
        pointer-events: none;
    }

    .bento-card h3 {
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #fff;
        letter-spacing: -0.02em;
    }

    .bento-card p {
        font-size: 1.05rem;
        color: #a1a1aa;
        line-height: 1.6;
        max-width: 90%;
    }

    .bento-large h3 {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
    }

    @media (max-width: 900px) {
        .bento-grid {
            grid-template-columns: 1fr;
            grid-template-rows: auto;
        }
        .bento-large,
        .bento-small,
        .bento-medium {
            grid-column: span 1;
        }
        .bento-card {
            padding: 2rem;
        }
    }
</style>

<script>
    import { gsap } from "gsap";

    document.querySelectorAll(".magnetic-card").forEach((card) => {
        const el = card as HTMLElement;

        el.addEventListener("mousemove", (e) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            // Update glow position
            el.style.setProperty("--mouse-x", `${x - 175}px`);
            el.style.setProperty("--mouse-y", `${y - 175}px`);

            // Magnetic 3D tilt
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            gsap.to(el, {
                duration: 0.5,
                rotateX: (y - centerY) / 20,
                rotateY: (centerX - x) / 20,
                transformPerspective: 1000,
                ease: "power2.out",
            });
        });

        el.addEventListener("mouseleave", () => {
            gsap.to(el, {
                duration: 0.7,
                rotateX: 0,
                rotateY: 0,
                ease: "elastic.out(1, 0.3)",
            });
        });
    });
</script>
