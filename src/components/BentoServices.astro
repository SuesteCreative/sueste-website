        size: "small",
        accent: "#22d3ee",
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/><path d="M7 4l-3 3"/><path d="M17 4l3 3"/><path d="M7 20l-3 -3"/><path d="M17 20l3 -3"/><path d="M4 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M4 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/></svg>`,
        iconBig: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/><path d="M7 4l-3 3"/><path d="M17 4l3 3"/><path d="M7 20l-3 -3"/><path d="M17 20l3 -3"/><path d="M4 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 7m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M4 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/><path d="M20 17m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/></svg>`,
    },
    {
        id: "social",
        title: "Social Media",
        descPt: "Gestão de autoridade e conteúdo estratégico que constrói comunidades em torno da sua marca.",
        descEn: "Authority management and strategic content that builds communities around your brand.",
        size: "small",
        accent: "#a78bfa",
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><line x1="15.18" y1="5.73" x2="8.82" y2="9.27"/><line x1="8.82" y1="14.73" x2="15.18" y2="18.27"/></svg>`,
        iconBig: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><line x1="15.18" y1="5.73" x2="8.82" y2="9.27"/><line x1="8.82" y1="14.73" x2="15.18" y2="18.27"/></svg>`,
    },
    {
        id: "graphic",
        title: "Graphic Design",
        descPt: "Identidade visual premium que comunica sofisticação e liderança no seu setor.",
        descEn: "Premium visual identity that communicates sophistication and leadership in your sector.",
        size: "medium",
        accent: "#fbbf24",
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
