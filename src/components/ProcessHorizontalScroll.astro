---
const { lang = "pt" } = Astro.props;

const processData = [
    {
        step: "01",
        titlePt: "Discovery & Estratégia",
        titleEn: "Discovery & Strategy",
        descPt: "Iniciamos com uma imersão profunda no seu ecossistema. Analisamos detalhadamente os seus objetivos de negócio, o comportamento do seu público-alvo e a movimentação da concorrência para traçar um roteiro estratégico que garanta uma vantagem competitiva real.",
        descEn: "We start with a deep immersion into your ecosystem. We analyze your business goals, target audience behavior, and competitor movements in detail to map out a strategic roadmap that ensures a real competitive edge.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="panel-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    },
    {
        step: "02",
        titlePt: "Design & Experiência",
        titleEn: "Design & Experience",
        descPt: "Transformamos estratégia em interfaces memoráveis. Criamos uma identidade visual impactante e um design focado na conversão, onde cada interação é pensada para guiar o utilizador de forma fluida e intuitiva através da jornada da sua marca.",
        descEn: "We transform strategy into memorable interfaces. We create an impactful visual identity and a conversion-focused design, where every interaction is designed to guide the user fluently and intuitively through your brand journey.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="panel-icon"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 5 5"/><path d="m5.2 11.7 4.2 4.2"/></svg>`,
    },
    {
        step: "03",
        titlePt: "Desenvolvimento & Performance",
        titleEn: "Development & Performance",
        descPt: "Damos vida à visão com tecnologia de última geração. O nosso desenvolvimento foca-se em código limpo, animações ultra-suaves e tempos de carregamento instantâneos, garantindo que o seu projeto não seja apenas bonito, mas tecnicamente impecável.",
        descEn: "We bring vision to life with state-of-the-art technology. Our development focuses on clean code, ultra-smooth animations, and instant loading times, ensuring your project is not only beautiful but technically flawless.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="panel-icon"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
    },
    {
        step: "04",
        titlePt: "Lançamento",
        titleEn: "Launch",
        descPt: "Chegou o momento de apresentar o seu projeto ao mundo. Realizamos uma transição suave e controlada, garantindo que tudo funcione impecavelmente no dia mais importante da jornada digital da sua marca.",
        descEn: "The moment to present your project to the world has arrived. We perform a smooth and controlled transition, ensuring everything works flawlessly on the most important day of your brand's digital journey.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="panel-icon"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"/><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"/></svg>`,
    },
    {
        step: "05",
        titlePt: "Resultados & Escala",
        titleEn: "Results & Scale",
        descPt: "O sucesso não termina no lançamento. Implementamos uma monitorização contínua de performance e SEO para assegurar que a sua presença digital continue a crescer e a entregar resultados mensuráveis.",
        descEn: "Success doesn't end at launch. We implement continuous performance and SEO monitoring to ensure your digital presence continues to grow and deliver measurable results.",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="panel-icon"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
        highlight: true,
    },
];
---

<div class="process-horizontal-container" id="process-pin-container">
    <div class="process-bg-blob"></div>
    <div class="process-sticky-left" data-reveal>
        <div class="sticky-content">
            <h2 class="process-title reveal-delay-1" data-reveal>
                {lang === "pt" ? "O Nosso Processo" : "Our Process"}
            </h2>
            <p class="process-subtitle reveal-delay-2" data-reveal>
                {
                    lang === "pt"
                        ? "Metodologia testada para transformar ideias em presenças digitais dominantes."
                        : "Tested methodology to transform ideas into dominating digital presences."
                }
            </p>
        </div>
    </div>

    <div class="process-scroll-right">
        <div class="horizontal-scroll-track" id="process-track">
            {
                processData.map((item, index) => (
                    <div
                        class={`process-panel glass ${
                            item.highlight ? "panel-highlight" : ""
                        } reveal-delay-${(index % 3) + 1}`}
                        data-reveal
                    >
                        <div class="panel-inner">
                            <div class="panel-header-row">
                                <span class="step-num">{item.step}</span>
                                <div
                                    class="icon-container"
                                    set:html={item.icon}
                                />
                            </div>
                            <div class="panel-content">
                                <h3>
                                    {lang === "pt"
                                        ? item.titlePt
                                        : item.titleEn}
                                </h3>
                                <p>
                                    {lang === "pt" ? item.descPt : item.descEn}
                                </p>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</div>

<style>
    .process-horizontal-container {
        display: flex;
        position: relative;
        /* We don't hide overflow here, GSAP needs to read the scroll bounds */
        padding: 8rem 0;
        background: transparent;
    }

    .process-bg-blob {
        position: absolute;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(
            circle,
            rgba(37, 99, 235, 0.2) 0%,
            transparent 70%
        );
        filter: blur(80px);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 0;
        pointer-events: none;
    }

    /* LEFT SIDE (Static/Sticky Title) */
    .process-sticky-left {
        width: 35%;
        flex-shrink: 0;
        padding-right: 4rem;
        position: relative;
    }

    .sticky-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
    }

    .process-title {
        font-size: clamp(3rem, 5vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .process-subtitle {
        font-size: 1.25rem;
        color: #a1a1aa;
        line-height: 1.6;
        max-width: 90%;
    }

    /* RIGHT SIDE (Horizontal Scrolling Panels) */
    .process-scroll-right {
        width: 65%;
        /* Hide overflow horizontally to mask the scrolling track */
        overflow: hidden;
    }

    .horizontal-scroll-track {
        display: flex;
        gap: 3rem;
        width: max-content; /* Force it to be as wide as all panels */
        /* Padding right to allow the last item to reach the center */
        padding-right: 3rem;
    }

    .process-panel {
        width: 750px;
        min-height: 520px;
        flex-shrink: 0;
        border-radius: 40px;
        padding: 4rem;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.4s ease;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px);
        position: relative;
    }

    .process-panel.panel-highlight {
        border: 2px solid #38bdf8;
        box-shadow: 0 0 30px rgba(56, 189, 248, 0.2),
            inset 0 0 20px rgba(56, 189, 248, 0.1);
        background: rgba(56, 189, 248, 0.05);
    }

    .process-panel.panel-highlight .step-num {
        background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        opacity: 0.4;
    }

    .process-panel.panel-highlight .icon-container {
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, 0.3);
    }

    .panel-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        width: 100%;
        margin-bottom: 2rem;
    }

    .icon-container {
        width: 6rem;
        height: 6rem;
        color: rgba(255, 255, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.05) 0%,
            rgba(255, 255, 255, 0) 100%
        );
        border-radius: 20px;
        padding: 1.5rem;
    }

    .icon-container :global(.panel-icon) {
        width: 100%;
        height: 100%;
        stroke-width: 1;
        opacity: 0.8;
    }

    .step-num {
        font-size: 6rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.1) 0%,
            rgba(255, 255, 255, 0) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: block;
        margin-bottom: 2rem;
    }

    .panel-content h3 {
        font-size: 2.25rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 1rem;
    }

    .panel-content p {
        font-size: 1.15rem;
        color: #a1a1aa;
        line-height: 1.5;
    }

    /* Mobile Carousel - replace stack with horizontal swipe */
    @media (max-width: 1024px) {
        .process-horizontal-container {
            flex-direction: column;
            padding: 4rem 0;
            overflow: hidden;
        }

        .process-sticky-left,
        .process-scroll-right {
            width: 100%;
        }

        .process-sticky-left {
            padding-right: 0;
            margin-bottom: 2rem;
            padding: 0 1.5rem;
        }

        .sticky-content {
            position: static;
        }

        .process-scroll-right {
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            padding: 1rem 1.5rem 2rem;
            scrollbar-width: none; /* Hide scrollbar Firefox */
        }

        .process-scroll-right::-webkit-scrollbar {
            display: none; /* Hide scrollbar Chrome/Safari */
        }

        .horizontal-scroll-track {
            flex-direction: row;
            width: max-content;
            padding-right: 1.5rem;
            gap: 1.25rem;
        }

        .process-panel {
            width: calc(100vw - 4rem);
            min-height: auto;
            max-width: 400px;
            padding: 2.5rem;
            scroll-snap-align: center;
            flex-shrink: 0;
        }

        .step-num {
            margin-bottom: 1rem;
            font-size: 3.5rem;
        }

        .panel-content h3 {
            font-size: 1.75rem;
        }

        .panel-content p {
            font-size: 1rem;
        }

        .icon-container {
            width: 4.5rem;
            height: 4.5rem;
            padding: 1rem;
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Only run GSAP horizontal scroll on desktop screens
    const mm = gsap.matchMedia();

    mm.add("(min-width: 1025px)", () => {
        const containers = document.querySelectorAll("#process-pin-container");

        containers.forEach((container) => {
            const track = container.querySelector(
                "#process-track"
            ) as HTMLElement;

            // Calculate how far the track needs to slide left.
            // Subtract padding-right so there's no dead scroll after the last card.
            const scrollRight = container.querySelector(".process-scroll-right") as HTMLElement;
            const getScrollAmount = () => {
                const trackPad = parseFloat(getComputedStyle(track).paddingRight) || 0;
                return -(track.scrollWidth - trackPad - scrollRight.offsetWidth);
            };

            const tween = gsap.to(track, {
                x: getScrollAmount,
                ease: "none",
                overwrite: "auto",
            });

            ScrollTrigger.create({
                trigger: container,
                start: "top top",
                end: () => `+=${getScrollAmount() * -1}`,
                animation: tween,
                pin: true,
                scrub: 1,
                invalidateOnRefresh: true,
            });
        });
    });
</script>
