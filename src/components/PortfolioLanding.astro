---
interface Project {
    title: string;
    categoryPt: string;
    categoryEn: string;
    metricPt: string;
    metricEn: string;
    metricLabelPt: string;
    metricLabelEn: string;
    image: string;
    size: "small" | "large";
    link: string;
    internalLink: string;
    altPt: string;
    altEn: string;
    hoverPt: string;
    hoverEn: string;
    deviceType: string;
}

const projects: Project[] = [
    {
        title: "Desportos Náuticos de Alvor",
        categoryPt: "E-Commerce & Merch",
        categoryEn: "E-Commerce & Merch",
        metricPt: "E-commerce",
        metricEn: "E-commerce",
        metricLabelPt: "Reservas Online",
        metricLabelEn: "Online Bookings",
        image: "/images/LandingPage/landing-dna-mockup.webp",
        size: "small",
        link: "https://desportosnauticosalvor.com/",
        internalLink: "https://desportosnauticosalvor.com/",
        altPt: "Mockup do website Desportos Náuticos de Alvor",
        altEn: "Desportos Náuticos de Alvor website mockup",
        hoverPt: "Explorar Website",
        hoverEn: "Explore Website",
        deviceType: "ipad",
    },
    {
        title: "Mental8Works",
        categoryPt: "Sys & Backoffice",
        categoryEn: "Sys & Backoffice",
        metricPt: "Site Dinâmico",
        metricEn: "Dynamic Site",
        metricLabelPt: "Custom Backoffice",
        metricLabelEn: "Custom Backoffice",
        image: "/images/LandingPage/landing-mental8works-mockup.webp",
        size: "small",
        link: "https://www.mental8works.pt/",
        internalLink: "https://www.mental8works.pt/",
        altPt: "Plataforma Mental8Works mockup",
        altEn: "Mental8Works platform mockup",
        hoverPt: "Ver Plataforma",
        hoverEn: "View Platform",
        deviceType: "macbook",
    },
    {
        title: "Algo Atelier",
        categoryPt: "Arquitetura",
        categoryEn: "Architecture",
        metricPt: "Site Optimizado",
        metricEn: "Optimized Site",
        metricLabelPt: "98% SEO Score",
        metricLabelEn: "98% SEO Score",
        image: "/images/LandingPage/landing-algo-mockup.webp",
        size: "large",
        link: "https://algoatelier.pt/",
        internalLink: "https://algoatelier.pt/",
        altPt: "Portfólio Algo Atelier mockup",
        altEn: "Algo Atelier portfolio mockup",
        hoverPt: "Ver Portfólio",
        hoverEn: "View Portfolio",
        deviceType: "iphone",
    },
];

const { lang = "pt" } = Astro.props;
const isPt = lang === "pt";
const viewAllLabel = isPt ? "Ver Todos os Projetos" : "View All Projects";
const viewAllHref = isPt ? "/portfolio" : "/en/work";
---

<div class="portfolio-showcase-container">
    <div class="portfolio-list">
        {
            projects.map((project, idx) => {
                const isEven = idx % 2 === 0;
                return (
                    <div
                        class={`portfolio-row ${
                            isEven ? "row-left" : "row-right"
                        }`}
                        data-project-row
                    >
                        <div class="row-content" data-animate-left>
                            <div class="card-header">
                                <span class="category">
                                    {isPt
                                        ? project.categoryPt
                                        : project.categoryEn}
                                </span>
                                <h3>{project.title}</h3>
                            </div>

                            <div class="analytics-box">
                                <span
                                    class={`metric-value ${
                                        project.title === "Algo Atelier"
                                            ? "text-blue"
                                            : ""
                                    }`}
                                >
                                    {isPt ? project.metricPt : project.metricEn}
                                </span>
                                <span
                                    class={`metric-label ${
                                        project.title === "Algo Atelier"
                                            ? "text-white"
                                            : ""
                                    }`}
                                >
                                    {isPt
                                        ? project.metricLabelPt
                                        : project.metricLabelEn}
                                </span>
                            </div>

                            <a
                                href={project.internalLink}
                                class="btn-project desktop-only"
                            >
                                {lang === "pt" ? "Ver Projeto" : "View Project"}
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                    <polyline points="12 5 19 12 12 19" />
                                </svg>
                            </a>
                        </div>

                        <div class="row-mockup-container" data-animate-right>
                            <a
                                href={project.internalLink}
                                class={`portfolio-image-wrapper wrapper-${project.deviceType}`}
                            >
                                <div class="hover-badge">
                                    {isPt ? project.hoverPt : project.hoverEn}
                                </div>
                                <img
                                    src={project.image}
                                    class="portfolio-img"
                                    alt={isPt ? project.altPt : project.altEn}
                                    loading="lazy"
                                />
                            </a>
                        </div>

                        <a
                            href={project.internalLink}
                            class="btn-project mobile-only"
                            style="margin-top: 2rem;"
                            data-animate-left
                        >
                            {lang === "pt" ? "Ver Projeto" : "View Project"}
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="5" y1="12" x2="19" y2="12" />
                                <polyline points="12 5 19 12 12 19" />
                            </svg>
                        </a>
                    </div>
                );
            })
        }
    </div>

    <div class="portfolio-footer" data-reveal>
        <a href={viewAllHref} class="btn-outline">
            {viewAllLabel}
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                    points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </div>
</div>

<style>
    .portfolio-showcase-container {
        width: 100%;
        margin-top: 4rem;
    }

    .portfolio-list {
        display: flex;
        flex-direction: column;
        gap: 8rem;
    }

    .portfolio-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
    }

    .portfolio-row.row-right {
        flex-direction: row-reverse;
    }

    .row-content {
        flex: 1;
        max-width: 450px;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .row-mockup-container {
        flex: 1.5;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    .portfolio-image-wrapper {
        position: relative;
        width: 100%;
        border-radius: 20px;
        overflow: visible;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        display: block;
    }

    .wrapper-macbook {
        max-width: 700px;
    }

    .wrapper-ipad {
        max-width: 400px;
    }

    .wrapper-iphone {
        max-width: 350px;
    }

    .portfolio-img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 20px;
        transition: all 0.6s ease;
    }

    .portfolio-row:hover .portfolio-image-wrapper {
        transform: translateY(-10px) scale(1.02);
    }

    .hover-badge {
        position: absolute;
        top: -20px;
        right: 0;
        background: rgba(56, 189, 248, 0.9);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        z-index: 10;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s ease;
        pointer-events: none;
        box-shadow: 0 10px 20px rgba(56, 189, 248, 0.3);
        backdrop-filter: blur(5px);
    }

    .portfolio-row:hover .hover-badge {
        opacity: 1;
        transform: translateY(0);
    }

    .category {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #38bdf8;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: block;
    }

    .card-header h3 {
        font-size: clamp(1.8rem, 7vw, 3.5rem);
        font-weight: 800;
        color: #fff;
        margin: 0;
        line-height: 1.1;
    }

    .analytics-box {
        display: flex;
        flex-direction: column;
    }

    .metric-value {
        font-size: clamp(2rem, 8vw, 3.2rem);
        font-weight: 900;
        line-height: 1.1;
        background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -2px;
        padding-bottom: 0.1em;
    }

    .metric-value.text-blue {
        background: none;
        -webkit-text-fill-color: #38bdf8;
        color: #38bdf8;
    }

    .metric-label {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 500;
        margin-top: 0.25rem;
    }

    .btn-project {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 600;
        width: fit-content;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-project:hover {
        background: rgba(56, 189, 248, 0.8);
        transform: translateY(-2px);
    }

    .portfolio-footer {
        margin-top: 4rem;
        display: flex;
        justify-content: center;
    }

    .btn-outline {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 600;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.02);
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: #38bdf8;
        transform: translateY(-2px);
    }

    /* Animation initial states */
    [data-animate-left] {
        opacity: 0;
        transform: translateX(-100px);
    }

    [data-animate-right] {
        opacity: 0;
        transform: translateX(100px);
    }

    /* Target the header of the parent section */
    :global(#portfolio .section-header) {
        opacity: 0;
        transform: translateY(30px);
    }

    @media (max-width: 1024px) {
        .portfolio-row,
        .portfolio-row.row-right {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }

        .row-content {
            align-items: center;
        }

        .row-mockup-container {
            width: 100%;
        }

        .portfolio-image-wrapper {
            max-width: 90%;
            margin: 0 auto;
        }

        .metric-value {
            font-size: clamp(1.4rem, 8vw, 2.2rem);
        }

        .hover-badge {
            display: none;
        }

        .mobile-only {
            display: inline-flex !important;
        }

        .desktop-only {
            display: none !important;
        }

        /* Mobile animations: slide from bottom instead? Or keep from sides? User asked from sides. */
        /* Let's keep from sides but maybe smaller offset */
        [data-animate-left],
        [data-animate-right] {
            transform: translateY(30px); /* Better for mobile to slide up */
        }
    }

    .desktop-only {
        display: inline-flex;
    }

    .mobile-only {
        display: none !important;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initPortfolioAnimations() {
        // 1. Animate Section Header (Fade in)
        const portfolioSection = document.querySelector("#portfolio");
        if (portfolioSection) {
            const header = portfolioSection.querySelector(".section-header");
            if (header) {
                gsap.fromTo(
                    header,
                    { opacity: 0, y: 30 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 1.2,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: header,
                            start: "top 85%",
                        },
                    },
                );
            }
        }

        // 2. Animate Project Rows
        const rows = document.querySelectorAll("[data-project-row]");

        rows.forEach((row) => {
            const leftCol = row.querySelector("[data-animate-left]");
            const rightCol = row.querySelector("[data-animate-right]");
            const mobileBtn = row.querySelector(
                ".mobile-only[data-animate-left]",
            );

            const isMobile = window.innerWidth <= 1024;

            if (isMobile) {
                // Mobile: Slide up
                gsap.to([leftCol, rightCol, mobileBtn], {
                    opacity: 1,
                    y: 0,
                    x: 0,
                    duration: 1,
                    stagger: 0.2,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: row,
                        start: "top 80%",
                    },
                });
            } else {
                // Desktop: Specific directionality
                if (leftCol) {
                    gsap.to(leftCol, {
                        opacity: 1,
                        x: 0,
                        duration: 1.2,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: row,
                            start: "top 75%",
                        },
                    });
                }

                if (rightCol) {
                    gsap.to(rightCol, {
                        opacity: 1,
                        x: 0,
                        duration: 1.2,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: row,
                            start: "top 75%",
                        },
                    });
                }
            }
        });
    }

    // Run on load and on Astro view transitions
    initPortfolioAnimations();
    document.addEventListener("astro:after-swap", initPortfolioAnimations);
</script>
