---
interface Project {
    title: string;
    category: string;
    metric: string;
    metricLabel: string;
    image: string;
    size: "small" | "large";
    link: string;
    internalLink: string;
    deviceType: "macbook" | "ipad" | "iphone";
}

const projects: Project[] = [
    {
        title: "Desportos Náuticos de Alvor",
        category: "E-Commerce & Merch",
        metric: "E-commerce",
        metricLabel: "Reservas Online",
        image: "/images/portfolio/desportos.jpg",
        size: "small",
        link: "https://desportosnauticosalvor.com/",
        internalLink: "/portfolio/desportos-nauticos-alvor",
        deviceType: "macbook",
    },
    {
        title: "Mental8Works",
        category: "Sys & Backoffice",
        metric: "Site Dinâmico",
        metricLabel: "Custom Backoffice",
        image: "/images/portfolio/mental8works.jpg",
        size: "small",
        link: "https://www.mental8works.pt/",
        internalLink: "/portfolio/mental8works",
        deviceType: "ipad",
    },
    {
        title: "Algo Atelier",
        category: "Architecture Algo Atelier",
        metric: "90%",
        metricLabel: "SEO Score",
        image: "/images/portfolio/algoatelier.jpg",
        size: "large",
        link: "https://algoatelier.pt/",
        internalLink: "/portfolio/algo-atelier",
        deviceType: "iphone",
    },
];

const { lang = "pt" } = Astro.props;
const viewAllLabel =
    lang === "pt" ? "Ver Todos os Projetos" : "View All Projects";
const viewAllHref = lang === "pt" ? "/portfolio" : "/en/work";
---

<div class="portfolio-showcase-container">
    <div class="portfolio-list">
        {
            projects.map((project, idx) => {
                const isEven = idx % 2 === 0;
                return (
                    <div
                        class={`portfolio-row ${
                            isEven ? "row-left" : "row-right"
                        }`}
                        data-reveal
                    >
                        <div class="row-content">
                            <div class="card-header">
                                <span class="category">{project.category}</span>
                                <h3>{project.title}</h3>
                            </div>

                            <div class="analytics-box">
                                <span class="metric-value">
                                    {project.metric}
                                </span>
                                <span class="metric-label">
                                    {project.metricLabel}
                                </span>
                            </div>

                            <a href={project.internalLink} class="btn-project">
                                {lang === "pt" ? "Ver Projeto" : "View Project"}
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                    <polyline points="12 5 19 12 12 19" />
                                </svg>
                            </a>
                        </div>

                        <div class="row-mockup-container">
                            {project.deviceType === "macbook" && (
                                <div class="mockup-macbook inline-mockup">
                                    <div class="hover-badge">
                                        Hover me{" "}
                                        <span class="cursor-icon">🖱️</span>
                                        <svg
                                            class="wrinkles"
                                            width="36"
                                            height="36"
                                            viewBox="0 0 36 36"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                        >
                                            <path
                                                d="M6 18 Q16 8 30 10"
                                                stroke="#38bdf8"
                                                stroke-width="3"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                            />
                                            <path
                                                d="M12 28 Q22 18 34 22"
                                                stroke="#38bdf8"
                                                stroke-width="3"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                            />
                                        </svg>
                                    </div>
                                    <div class="macbook-screen">
                                        <div
                                            class="mockup-scroll-container"
                                            data-mockup
                                        >
                                            <img
                                                src={project.image}
                                                class="mockup-img"
                                                alt={project.title}
                                                loading="lazy"
                                            />
                                        </div>
                                    </div>
                                    <div class="macbook-base">
                                        <div class="macbook-notch" />
                                    </div>
                                </div>
                            )}
                            {project.deviceType === "ipad" && (
                                <div class="mockup-ipad inline-mockup">
                                    <div class="ipad-screen">
                                        <div
                                            class="mockup-scroll-container"
                                            data-mockup
                                        >
                                            <img
                                                src={project.image}
                                                class="mockup-img"
                                                alt={project.title}
                                                loading="lazy"
                                            />
                                        </div>
                                    </div>
                                </div>
                            )}
                            {project.deviceType === "iphone" && (
                                <div class="mockup-iphone inline-mockup">
                                    <div class="iphone-notch" />
                                    <div class="iphone-screen">
                                        <div
                                            class="mockup-scroll-container"
                                            data-mockup
                                        >
                                            <img
                                                src={project.image}
                                                class="mockup-img"
                                                alt={project.title}
                                                loading="lazy"
                                            />
                                        </div>
                                    </div>
                                </div>
                            )}
                        </div>
                    </div>
                );
            })
        }
    </div>

    <div class="portfolio-footer" data-reveal>
        <a href={viewAllHref} class="btn-outline">
            {viewAllLabel}
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                    points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </div>
</div>

<style>
    .portfolio-showcase-container {
        width: 100%;
        margin-top: 4rem;
    }

    .portfolio-list {
        display: flex;
        flex-direction: column;
        gap: 8rem; /* Large gap between projects */
    }

    .portfolio-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
    }

    .portfolio-row.row-right {
        flex-direction: row-reverse;
    }

    .row-content {
        flex: 1;
        max-width: 450px;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .row-mockup-container {
        flex: 1.5;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    /* Ambient blob behind mockups */
    .row-mockup-container::before {
        content: "";
        position: absolute;
        width: 80%;
        height: 80%;
        background: radial-gradient(
            circle at center,
            rgba(37, 99, 235, 0.15) 0%,
            transparent 70%
        );
        z-index: -1;
    }

    /* Mockups Base */
    .inline-mockup {
        position: relative;
        z-index: 10;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .portfolio-row:hover .inline-mockup {
        transform: translateY(-10px) scale(1.02);
    }

    /* Macbook Mockup */
    .mockup-macbook {
        width: 100%;
        max-width: 700px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .macbook-screen {
        width: 100%;
        aspect-ratio: 16 / 10;
        background: #000;
        border-radius: 12px 12px 0 0;
        border: 8px solid #1a1a1a;
        border-bottom: 12px solid #1a1a1a;
        overflow: hidden;
        position: relative;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }
    .macbook-base {
        width: 120%;
        height: 12px;
        background: #2a2a2a;
        border-radius: 0 0 16px 16px;
        position: relative;
        display: flex;
        justify-content: center;
        box-shadow: inset 0 -2px 5px rgba(0, 0, 0, 0.5);
    }
    .macbook-notch {
        width: 15%;
        height: 4px;
        background: #111;
        border-radius: 0 0 4px 4px;
        position: absolute; /* Fix notch placement */
        top: 0;
    }

    .hover-badge {
        position: absolute;
        top: -30px;
        right: -30px;
        background: rgba(56, 189, 248, 0.9);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        transform: rotate(10deg);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        z-index: 20;
        pointer-events: none;
        animation: float-badge 3s ease-in-out infinite;
    }

    .wrinkles {
        position: absolute;
        right: -30px;
        top: -15px;
        transform: rotate(20deg);
        pointer-events: none;
    }

    @keyframes float-badge {
        0%,
        100% {
            transform: translateY(0) rotate(10deg);
        }
        50% {
            transform: translateY(-8px) rotate(12deg);
        }
    }

    .cursor-icon {
        font-size: 1rem;
        margin-left: 0.25rem;
    }

    /* iPad Mockup */
    .mockup-ipad {
        width: 60%;
        max-width: 450px;
    }
    .ipad-screen {
        width: 100%;
        aspect-ratio: 3 / 4;
        background: #000;
        border-radius: 24px;
        border: 14px solid #1a1a1a;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    /* iPhone Mockup */
    .mockup-iphone {
        width: 45%;
        max-width: 320px;
    }
    .iphone-screen {
        width: 100%;
        aspect-ratio: 9 / 19.5;
        background: #000;
        border-radius: 36px;
        border: 10px solid #1a1a1a;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }
    .iphone-notch {
        position: absolute;
        top: 10px;
        left: 50%;
        transform: translateX(-50%);
        width: 35%;
        height: 25px;
        background: #1a1a1a;
        border-radius: 0 0 16px 16px;
        z-index: 10;
    }

    .mockup-scroll-container {
        width: 100%;
        height: 100%;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .mockup-img {
        width: 100%;
        height: auto;
        position: absolute;
        top: 0;
        left: 0;
        transition: transform 15s linear;
        transform: translateY(0);
        will-change: transform;
    }

    /* Desktop Hover Behavior */
    @media (min-width: 1025px) {
        .portfolio-row:hover .mockup-img {
            transform: translateY(
                calc(-100% + 100%)
            ); /* Fallback logic handled by JS for precise calc */
        }
    }

    /* Mobile Auto-scrolling state */
    .mockup-scroll-container.is-autoscrolling .mockup-img {
        /* Animation handled by JS for smooth looping */
        transition: none;
    }

    .category {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #38bdf8;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: block;
    }

    .card-header h3 {
        font-size: 3.5rem;
        font-weight: 800;
        color: #fff;
        margin: 0;
        line-height: 1.1;
    }

    .analytics-box {
        display: flex;
        flex-direction: column;
    }

    .metric-value {
        font-size: 4rem;
        font-weight: 900;
        line-height: 1.1;
        background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -2px;
        padding-bottom: 0.1em; /* Prevent clipping */
    }

    .metric-label {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 500;
        margin-top: 0.25rem;
    }

    .card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .btn-project {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-project:hover {
        background: rgba(56, 189, 248, 0.8);
        transform: translateY(-2px);
    }

    .portfolio-footer {
        margin-top: 4rem;
        display: flex;
        justify-content: center;
    }

    .btn-outline {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 600;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.02);
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: #38bdf8;
        transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
        .portfolio-row,
        .portfolio-row.row-right {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }

        .row-content {
            align-items: center;
        }

        .row-mockup-container {
            width: 100%;
        }

        .mockup-ipad {
            width: 80%;
        }
        .mockup-iphone {
            width: 60%;
        }

        .metric-value {
            font-size: 3rem;
        }
    }
</style>

<script>
    function setupMockups() {
        const mockupContainers = document.querySelectorAll("[data-mockup]");

        mockupContainers.forEach((container) => {
            const img = container.querySelector(
                ".mockup-img"
            ) as HTMLImageElement;
            if (!img) return;

            let animationId: number | null = null;
            let currentTranslateY = 0;
            const scrollSpeed = 1.2; // pixels per frame

            function getScrollParams() {
                const containerHeight = container.clientHeight;
                const imageHeight = img.getBoundingClientRect().height;
                const maxTranslate = containerHeight - imageHeight;
                return { maxTranslate, containerHeight, imageHeight };
            }

            // Handle hover for desktop
            container.addEventListener("mouseenter", () => {
                if (window.innerWidth > 1024) {
                    const { maxTranslate } = getScrollParams();
                    if (maxTranslate >= 0) return;

                    const duration = Math.abs(maxTranslate) / 100; // 100px per second
                    img.style.transition = `transform ${duration}s linear`;
                    img.style.transform = `translateY(${maxTranslate}px)`;
                }
            });

            container.addEventListener("mouseleave", () => {
                if (window.innerWidth > 1024) {
                    img.style.transition = "transform 2s ease-in-out";
                    img.style.transform = "translateY(0)";
                }
            });

            // Handle tap for mobile
            container.addEventListener("click", (e) => {
                if (window.innerWidth <= 1024) {
                    e.preventDefault();
                    const isAutoscrolling =
                        container.classList.toggle("is-autoscrolling");

                    if (isAutoscrolling) {
                        startAutoScroll();
                    } else {
                        stopAutoScroll();
                    }
                }
            });

            function startAutoScroll() {
                const { maxTranslate } = getScrollParams();
                if (maxTranslate >= 0) return;

                function step() {
                    if (!container.classList.contains("is-autoscrolling"))
                        return;

                    currentTranslateY -= scrollSpeed;
                    if (currentTranslateY <= maxTranslate) {
                        currentTranslateY = 0; // Loop back
                    }

                    img.style.transform = `translateY(${currentTranslateY}px)`;
                    animationId = requestAnimationFrame(step);
                }

                img.style.transition = "none";
                animationId = requestAnimationFrame(step);
            }

            function stopAutoScroll() {
                if (animationId) {
                    cancelAnimationFrame(animationId);
                    animationId = null;
                }
                img.style.transition = "transform 0.5s ease-out";
                // Optionally reset or stay put? We stay put and let user tap again.
            }

            // Ensure we handle image loading
            if (!img.complete) {
                img.addEventListener("load", () => {
                    // Force a recalculation if needed
                });
            }
        });
    }

    // Initialize after DOM and Astro transitions
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupMockups);
    } else {
        setupMockups();
    }
    document.addEventListener("astro:after-swap", setupMockups);
</script>
