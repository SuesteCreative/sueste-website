---
interface Project {
    title: string;
    category: string;
    metric: string;
    metricLabel: string;
    image: string;
    size: "small" | "large";
    link: string;
    deviceType: "macbook" | "ipad" | "iphone";
}

const projects: Project[] = [
    {
        title: "Desportos Náuticos de Alvor",
        category: "E-Commerce & Merch",
        metric: "Web",
        metricLabel: "Shopify Store",
        image: "/images/portfolio/desportos.jpg",
        size: "small",
        link: "https://desportosnauticosalvor.com/",
        deviceType: "macbook",
    },
    {
        title: "Mental8Works",
        category: "Pyschology & Health",
        metric: "Sys",
        metricLabel: "Custom Backoffice",
        image: "/images/portfolio/mental8works.jpg",
        size: "small",
        link: "https://www.mental8works.pt/",
        deviceType: "ipad",
    },
    {
        title: "Algo Atelier",
        category: "Architecture",
        metric: "90+",
        metricLabel: "SEO Score",
        image: "/images/portfolio/algoatelier.jpg",
        size: "large",
        link: "https://algoatelier.pt/",
        deviceType: "iphone",
    },
];

const { lang = "pt" } = Astro.props;
const viewAllLabel =
    lang === "pt" ? "Ver Todos os Projetos" : "View All Projects";
const viewAllHref = lang === "pt" ? "/portfolio" : "/en/work";
---

<div class="portfolio-grid-container">
    <div class="portfolio-grid">
        {
            projects.map((project, idx) => (
                <div
                    class={`portfolio-card ${project.size}`}
                    data-reveal
                    class:list={[`reveal-delay-${idx + 1}`]}
                >
                    <div class="card-image-wrapper">
                        {project.deviceType === "macbook" && (
                            <div class="mockup-macbook">
                                <div class="macbook-screen">
                                    <img
                                        src={project.image}
                                        alt={project.title}
                                        class="mockup-img"
                                    />
                                </div>
                                <div class="macbook-base">
                                    <div class="macbook-notch" />
                                </div>
                            </div>
                        )}
                        {project.deviceType === "ipad" && (
                            <div class="mockup-ipad">
                                <div class="ipad-screen">
                                    <img
                                        src={project.image}
                                        alt={project.title}
                                        class="mockup-img"
                                    />
                                </div>
                            </div>
                        )}
                        {project.deviceType === "iphone" && (
                            <div class="mockup-iphone">
                                <div class="iphone-notch" />
                                <div class="iphone-screen">
                                    <img
                                        src={project.image}
                                        alt={project.title}
                                        class="mockup-img"
                                    />
                                </div>
                            </div>
                        )}
                        <div class="card-overlay" />
                    </div>

                    <div class="card-content">
                        <div class="card-header">
                            <span class="category">{project.category}</span>
                            <h3>{project.title}</h3>
                        </div>

                        <div class="card-bottom">
                            <div class="analytics-box">
                                <span class="metric-value">
                                    {project.metric}
                                </span>
                                <span class="metric-label">
                                    {project.metricLabel}
                                </span>
                            </div>
                            <a
                                href={project.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn-project"
                            >
                                {lang === "pt" ? "Ver Projeto" : "View Website"}
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                    <polyline points="12 5 19 12 12 19" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>

    <div class="portfolio-footer" data-reveal>
        <a href={viewAllHref} class="btn-outline">
            {viewAllLabel}
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                    points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </div>
</div>

<style>
    .portfolio-grid-container {
        width: 100%;
        margin-top: 4rem;
    }

    .portfolio-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 400px 400px;
        gap: 2rem;
    }

    .portfolio-card {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .portfolio-card.large {
        grid-column: 2;
        grid-row: 1 / span 2;
    }

    .portfolio-card:hover {
        transform: translateY(-8px);
        border-color: rgba(56, 189, 248, 0.3);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .card-image-wrapper {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        /* Ambient subtle radial background */
        background: radial-gradient(
            circle at center,
            rgba(37, 99, 235, 0.1) 0%,
            transparent 60%
        );
    }

    /* Macbook Mockup */
    .mockup-macbook {
        position: absolute;
        width: 85%;
        max-width: 500px;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 0;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        transform: translateY(20px);
    }
    .portfolio-card:hover .mockup-macbook {
        transform: translateY(0px) scale(1.02);
    }
    .macbook-screen {
        width: 100%;
        aspect-ratio: 16 / 10;
        background: #000;
        border-radius: 12px 12px 0 0;
        border: 8px solid #1a1a1a;
        border-bottom: 12px solid #1a1a1a;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
    }
    .macbook-base {
        width: 120%;
        height: 12px;
        background: #2a2a2a;
        border-radius: 0 0 16px 16px;
        position: relative;
        display: flex;
        justify-content: center;
        box-shadow: inset 0 -2px 5px rgba(0, 0, 0, 0.5);
    }
    .macbook-notch {
        width: 15%;
        height: 4px;
        background: #111;
        border-radius: 0 0 4px 4px;
    }

    /* iPad Mockup */
    .mockup-ipad {
        position: absolute;
        width: 70%;
        max-width: 320px;
        z-index: 0;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        transform: translateY(20px);
    }
    .portfolio-card:hover .mockup-ipad {
        transform: translateY(0px) scale(1.02);
    }
    .ipad-screen {
        width: 100%;
        aspect-ratio: 3 / 4;
        background: #000;
        border-radius: 24px;
        border: 14px solid #1a1a1a;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
    }

    /* iPhone Mockup */
    .mockup-iphone {
        position: absolute;
        width: 75%;
        max-width: 280px;
        z-index: 0;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        transform: translateY(20px);
    }
    .portfolio-card:hover .mockup-iphone {
        transform: translateY(0px) scale(1.02);
    }
    .iphone-screen {
        width: 100%;
        aspect-ratio: 9 / 19.5;
        background: #000;
        border-radius: 36px;
        border: 10px solid #1a1a1a;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
    }
    .iphone-notch {
        position: absolute;
        top: 10px;
        left: 50%;
        transform: translateX(-50%);
        width: 35%;
        height: 25px;
        background: #1a1a1a;
        border-radius: 0 0 16px 16px;
        z-index: 10;
    }

    .mockup-img {
        width: 100%;
        height: auto;
        object-fit: cover;
        object-position: top;
        opacity: 0.8;
        transition: transform 4s ease, opacity 0.6s ease;
    }

    .portfolio-card:hover .mockup-img {
        opacity: 1;
        /* Slow pan effect for tall screenshots */
        transform: translateY(-5%);
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.95) 0%,
            rgba(0, 0, 0, 0.5) 40%,
            transparent 100%
        );
    }

    .card-content {
        position: relative;
        z-index: 1;
        height: 100%;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .category {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #38bdf8;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: block;
    }

    .card-content h3 {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        margin: 0;
    }

    .analytics-box {
        display: flex;
        flex-direction: column;
    }

    .metric-value {
        font-size: 4rem;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -2px;
    }

    .metric-label {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 500;
        margin-top: 0.25rem;
    }

    .card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .btn-project {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-project:hover {
        background: rgba(56, 189, 248, 0.8);
        transform: translateY(-2px);
    }

    .portfolio-footer {
        margin-top: 4rem;
        display: flex;
        justify-content: center;
    }

    .btn-outline {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 600;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.02);
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: #38bdf8;
        transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
        .portfolio-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(3, 400px);
        }

        .portfolio-card.large {
            grid-column: 1;
            grid-row: auto;
        }

        .metric-value {
            font-size: 3rem;
        }
    }
</style>
