---
interface Project {
    title: string;
    categoryPt: string;
    categoryEn: string;
    descPt: string;
    descEn: string;
    tag: string;
    image: string;
    link: string;
    altPt: string;
    altEn: string;
    accent: string;
}

const projects: Project[] = [
    {
        title: "Desportos Náuticos de Alvor",
        categoryPt: "E-Commerce & Merch",
        categoryEn: "E-Commerce & Merch",
        descPt: "Sistema de reservas online e gestão de inventário para a maior escola de desportos náuticos do Algarve.",
        descEn: "Online booking system and inventory management for the largest water sports school in the Algarve.",
        tag: "Website",
        image: "/images/LandingPage/landing-dna-mockup.webp",
        link: "https://desportosnauticosalvor.com/",
        altPt: "Mockup website Desportos Náuticos de Alvor",
        altEn: "Desportos Náuticos de Alvor website mockup",
        accent: "#38bdf8",
    },
    {
        title: "Mental8Works",
        categoryPt: "Sys & Backoffice",
        categoryEn: "Sys & Backoffice",
        descPt: "Plataforma de gestão de saúde mental corporativa com backoffice customizado e análise de dados em tempo real.",
        descEn: "Corporate mental health management platform with custom backoffice and real-time data analysis.",
        tag: "Platform",
        image: "/images/LandingPage/landing-mental8works-mockup.webp",
        link: "https://www.mental8works.pt/",
        altPt: "Plataforma Mental8Works mockup",
        altEn: "Mental8Works platform mockup",
        accent: "#a78bfa",
    },
    {
        title: "Algo Atelier",
        categoryPt: "Architecture & SEO",
        categoryEn: "Architecture & SEO",
        descPt: "Presença digital de alta performance para um atelier de arquitetura, focada em estética minimalista e SEO técnico.",
        descEn: "High-performance digital presence for an architecture studio, focused on minimalist aesthetics and technical SEO.",
        tag: "98% SEO",
        image: "/images/LandingPage/landing-algo-mockup.webp",
        link: "https://algoatelier.pt/",
        altPt: "Portfólio Algo Atelier mockup",
        altEn: "Algo Atelier portfolio mockup",
        accent: "#fbbf24",
    },
    {
        title: "DNA — CRM & Backoffice",
        categoryPt: "CRM & Backoffice",
        categoryEn: "CRM & Backoffice",
        descPt: "Sistema de gestão interna com CRM personalizado, controlo de stocks e dashboards de performance em tempo real.",
        descEn: "Internal management system with custom CRM, stock control, and real-time performance dashboards.",
        tag: "Custom CRM",
        // TODO: replace with dedicated CRM screenshot when available
        image: "/images/LandingPage/landing-dna-mockup.webp",
        link: "https://desportosnauticosalvor.com/",
        altPt: "Sistema CRM Desportos Náuticos de Alvor",
        altEn: "Desportos Náuticos de Alvor CRM system",
        accent: "#22d3ee",
    },
];

const { lang = "pt" } = Astro.props;
const isPt = lang === "pt";
const viewAllLabel = isPt ? "Ver Todos os Projetos" : "View All Projects";
const viewAllHref = isPt ? "/portfolio" : "/en/work";
---

<div class="portfolio-showcase-container">
    <div class="portfolio-grid">
        {
            projects.map((project, idx) => (
                <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`pcard pcard-${idx + 1}`}
                    data-reveal
                    style={`--accent: ${project.accent};`}
                    aria-label={isPt ? project.altPt : project.altEn}
                >
                    <img
                        class="pcard-bg"
                        src={project.image}
                        alt={isPt ? project.altPt : project.altEn}
                        loading="lazy"
                    />
                    <div class="pcard-gradient" />
                    <div class="pcard-content">
                        <span class="pcard-cat">
                            {isPt ? project.categoryPt : project.categoryEn}
                        </span>
                        <h3 class="pcard-title">{project.title}</h3>
                        <p class="pcard-desc">
                            {isPt ? project.descPt : project.descEn}
                        </p>
                        <span class="pcard-cta">
                            {isPt ? "Ver Projeto" : "View Project"}
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="7" y1="17" x2="17" y2="7" />
                                <polyline points="7 7 17 7 17 17" />
                            </svg>
                        </span>
                    </div>
                    <span class="pcard-tag">{project.tag}</span>
                </a>
            ))
        }
    </div>

    <div class="portfolio-footer" data-reveal>
        <a href={viewAllHref} class="btn-view-all">
            {viewAllLabel}
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                    points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </div>
</div>

<style>
    .portfolio-showcase-container {
        width: 100%;
        margin-top: 3rem;
    }

    /* ── BENTO GRID ─────────────────────────────────────────────────────── */
    .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        grid-template-rows: 500px 500px;
        gap: 1.25rem;
    }

    /* Row 1: DNA large-left, Mental small-right */
    .pcard-1 { grid-column: 1 / 4; }
    .pcard-2 { grid-column: 4 / 6; }

    /* Row 2: Algo small-left, CRM large-right */
    .pcard-3 { grid-column: 1 / 3; }
    .pcard-4 { grid-column: 3 / 6; }

    /* ── CARD BASE ──────────────────────────────────────────────────────── */
    .pcard {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        display: block;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: border-color 0.4s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform;
    }

    .pcard:hover {
        border-color: color-mix(in srgb, var(--accent) 40%, transparent);
        transform: translateY(-6px);
        box-shadow: 0 20px 60px -15px color-mix(in srgb, var(--accent) 30%, transparent);
    }

    /* ── IMAGE ──────────────────────────────────────────────────────────── */
    .pcard-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .pcard:hover .pcard-bg {
        transform: scale(1.05);
    }

    /* ── GRADIENT OVERLAY ───────────────────────────────────────────────── */
    .pcard-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(5, 5, 12, 0.96) 0%,
            rgba(5, 5, 12, 0.65) 35%,
            rgba(5, 5, 12, 0.15) 65%,
            transparent 100%
        );
        transition: background 0.4s ease;
    }

    .pcard:hover .pcard-gradient {
        background: linear-gradient(
            to top,
            rgba(5, 5, 12, 0.98) 0%,
            rgba(5, 5, 12, 0.75) 40%,
            rgba(5, 5, 12, 0.2) 70%,
            transparent 100%
        );
    }

    /* ── CONTENT ────────────────────────────────────────────────────────── */
    .pcard-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 2rem 2.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .pcard-cat {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        display: block;
    }

    .pcard-title {
        font-size: clamp(1.25rem, 2.5vw, 1.75rem);
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin: 0;
        letter-spacing: -0.02em;
    }

    .pcard-desc {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.55;
        margin: 0.25rem 0 0;
        max-width: 95%;
    }

    .pcard-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--accent);
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.35s ease, transform 0.35s ease;
    }

    .pcard:hover .pcard-cta {
        opacity: 1;
        transform: translateY(0);
    }

    /* ── TAG BADGE (top-right) ──────────────────────────────────────────── */
    .pcard-tag {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        padding: 0.3rem 0.75rem;
        border-radius: 50px;
        background: color-mix(in srgb, var(--accent) 12%, rgba(0,0,0,0.5));
        border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
        color: var(--accent);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        backdrop-filter: blur(10px);
        z-index: 2;
    }

    /* ── FOOTER ─────────────────────────────────────────────────────────── */
    .portfolio-footer {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
    }

    .btn-view-all {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 600;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.02);
        text-decoration: none;
    }

    .btn-view-all:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: #38bdf8;
        transform: translateY(-2px);
    }

    /* ── RESPONSIVE ─────────────────────────────────────────────────────── */
    @media (max-width: 1024px) {
        .portfolio-grid {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: repeat(2, 420px);
        }
        .pcard-1 { grid-column: 1 / 2; }
        .pcard-2 { grid-column: 2 / 3; }
        .pcard-3 { grid-column: 1 / 2; }
        .pcard-4 { grid-column: 2 / 3; }
    }

    @media (max-width: 640px) {
        .portfolio-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(4, 380px);
            gap: 1rem;
        }
        .pcard-1, .pcard-2, .pcard-3, .pcard-4 { grid-column: 1 / 2; }

        .pcard-content { padding: 1.5rem 1.5rem 1.75rem; }
        .pcard-cta { opacity: 1; transform: none; }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initPortfolioAnimations() {
        const cards = document.querySelectorAll(".pcard");

        cards.forEach((card, i) => {
            gsap.fromTo(
                card,
                { opacity: 0, y: 40, scale: 0.97 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 0.9,
                    ease: "power3.out",
                    delay: (i % 2) * 0.12,
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                    },
                },
            );
        });
    }

    initPortfolioAnimations();
    document.addEventListener("astro:after-swap", initPortfolioAnimations);
</script>
