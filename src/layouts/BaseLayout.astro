---
import "../styles/global.css";
import { getLangFromUrl } from "../utils/i18n";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  hreflangPt?: string;
  hreflangEn?: string;
  preloadImage?: string;
}

const {
  title,
  description = "Sueste Creative - Creative Agency",
  lang: propLang,
  hreflangPt,
  hreflangEn,
  preloadImage,
} = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, "https://sueste-creative.pt");
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RE740MRY5Y"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-RE740MRY5Y");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Sueste Creative</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    {hreflangPt && <link rel="alternate" hreflang="pt" href={hreflangPt} />}
    {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
    {hreflangPt && <link rel="alternate" hreflang="x-default" href={hreflangPt} />}

    <meta name="author" content="Sueste Creative" />

    <!-- Open Graph (Facebook, Instagram, TikTok, LinkedIn, WhatsApp) -->
    <meta property="og:title" content={`${title} | Sueste Creative`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://sueste-creative.pt/images/logo-white-hor.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === "en" ? "en_GB" : "pt_PT"} />
    <meta property="og:site_name" content="Sueste Creative" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Sueste Creative`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://sueste-creative.pt/images/logo-white-hor.webp" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap"
      rel="stylesheet"
    />

    <!-- SEO: JSON-LD Schema -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: "Sueste Creative",
        alternateName: "Sueste Creative Agency",
        url: "https://sueste-creative.pt",
        logo: "https://sueste-creative.pt/images/logo-white-hor.webp",
        description: description,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Algarve",
          addressCountry: "PT",
        },
        sameAs: [
          "https://www.instagram.com/sueste.agency/",
          "https://www.facebook.com/sueste.agency",
          "https://linkedin.com/company/sueste-creative",
        ],
      })}
    ></script>
  </head>
  <body>
    <div class="bg-blob-container">
      <div class="bg-blob"></div>
      <div class="bg-blob-2"></div>
    </div>
    <slot />

    <script>
      // Load and Initialize Lenis & GSAP interactions
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // Setup smooth scrolling for the entire app
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: "vertical",
        gestureOrientation: "vertical",
        smoothWheel: true,
        wheelMultiplier: 1,
        infinite: false,
      });

      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // Handle Astro view transitions if used in future
      document.addEventListener("astro:after-swap", () => {
        // You could re-init Lenis here if the DOM swaps heavily
      });

      // Masterful Reveal System that we left working
      const revealCallback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
          }
        });
      };

      const revealObserver = new IntersectionObserver(revealCallback, {
        threshold: 0.15,
        rootMargin: "0px 0px -50px 0px",
      });

      document.querySelectorAll("[data-reveal]").forEach((el) => {
        revealObserver.observe(el);
      });

      document.addEventListener("astro:after-swap", () => {
        document
          .querySelectorAll("[data-reveal]")
          .forEach((el) => revealObserver.observe(el));
      });
    </script>
  </body>
</html>
