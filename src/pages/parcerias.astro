---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";

const partners = [
    {
        name: "Nádine Campos",
        subtitle: "photography & film production",
        slug: "nadine-campos",
        category: "Fotografia & Vídeo",
        description:
            "Captando a essência de cada momento através de uma lente artística e técnica.",
        logo: "/images/partners/SVG/logo-nadine-white.svg",
    },
];
---

<BaseLayout
    title="Parcerias"
    description="Conheça os parceiros que colaboram com a Sueste Creative."
>
    <Navbar />
    <main class="parcerias-page">
        <Section
            title="As Nossas Parcerias"
            subtitle="Colaboramos com os melhores talentos para entregar excelência em cada projeto."
        >
            <div class="partners-grid">
                {
                    partners.map((partner) => (
                        <a
                            href={`/parcerias/${partner.slug}`}
                            class="partner-card glass"
                            data-reveal
                        >
                            <div class="card-image">
                                <img
                                    src={partner.logo}
                                    alt={partner.name}
                                    class="partner-card-logo"
                                />
                                <div class="card-overlay" />
                            </div>
                            <div class="card-info">
                                <span>{partner.category}</span>
                                <h3 class="partner-title">
                                    <span class="main-name">
                                        {partner.name}
                                    </span>
                                    {partner.subtitle && (
                                        <span class="sub-name">
                                            {partner.subtitle}
                                        </span>
                                    )}
                                </h3>
                                <p>{partner.description}</p>
                            </div>
                        </a>
                    ))
                }
            </div>
        </Section>

        <Section
            title="Porquê Parcerias?"
            subtitle="A força da colaboração estratégica."
            dark
        >
            <div class="benefits-grid">
                <div class="benefit" data-reveal>
                    <div class="benefit-icon">🤝</div>
                    <h3>Sinergia Criativa</h3>
                    <p>
                        Unimos diferentes visões para criar algo maior do que a
                        soma das partes.
                    </p>
                </div>
                <div class="benefit" data-reveal class="reveal-delay-1">
                    <div class="benefit-icon">✨</div>
                    <h3>Especialização</h3>
                    <p>
                        Trabalhamos com especialistas focados no que fazem de
                        melhor.
                    </p>
                </div>
                <div class="benefit" data-reveal class="reveal-delay-2">
                    <div class="benefit-icon">🏆</div>
                    <h3>Qualidade Superior</h3>
                    <p>
                        Padrões de exigência elevados em todas as frentes de
                        produção.
                    </p>
                </div>
            </div>
        </Section>

        <Section id="cta" className="final-cta-partners">
            <div class="cta-inner text-center">
                <h2>Também queres colaborar?</h2>
                <p>
                    Estamos sempre à procura de novos talentos e empresas que
                    partilhem a nossa visão.
                </p>
                <div style="margin-top: 3rem;">
                    <a href="/contacto" class="btn-cta-partners"
                        >Quero Ser Parceiro</a
                    >
                </div>
            </div>
        </Section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .parcerias-page {
        padding-top: 80px;
    }

    .partners-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .partner-card {
        border-radius: 30px;
        overflow: hidden;
        transition: transform 0.5s cubic-bezier(0.2, 1, 0.3, 1);
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
    }

    .partner-card:hover {
        transform: translateY(-15px) scale(1.02);
        border-color: #38bdf8;
    }

    .card-image {
        aspect-ratio: 1 / 1;
        width: 100%;
        background: #000;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .partner-card-logo {
        max-width: 80%;
        max-height: 80%;
        object-fit: contain;
        filter: brightness(1.1);
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .partner-card:hover .card-overlay {
        opacity: 1;
    }

    .card-info {
        padding: 2.5rem;
    }

    .card-info span {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #38bdf8;
        margin-bottom: 0.75rem;
        display: block;
        font-weight: 700;
    }

    .partner-title {
        display: flex;
        flex-direction: column;
        margin-bottom: 1rem;
    }

    .main-name {
        font-size: 3rem;
        font-weight: 800;
        color: #fff !important;
        line-height: 1.1;
        text-transform: none; /* Ensure it doesn't get forced to uppercase if not desired */
    }

    .sub-name {
        font-size: 1.1rem;
        font-weight: 300;
        color: #fff !important;
        letter-spacing: 0.05em;
        font-style: italic;
        margin-top: 0.25rem;
        opacity: 0.9;
    }

    .card-info p {
        opacity: 0.6;
        font-size: 1rem;
        line-height: 1.6;
        color: #a1a1aa;
    }

    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
        margin-top: 3rem;
    }

    .benefit {
        text-align: center;
        background: rgba(255, 255, 255, 0.02);
        padding: 4rem 2rem;
        border-radius: 32px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.4s ease;
    }

    .benefit:hover {
        transform: translateY(-10px);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .benefit-icon {
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        display: block;
    }

    .benefit h3 {
        font-size: 1.6rem;
        margin-bottom: 1rem;
        color: white;
    }

    .benefit p {
        font-size: 1.05rem;
        opacity: 0.6;
        line-height: 1.6;
    }

    .cta-inner {
        padding: 8rem 0;
    }

    .final-cta-partners h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        margin-bottom: 1.5rem;
    }

    .btn-cta-partners {
        display: inline-flex;
        align-items: center;
        padding: 1.25rem 3.5rem;
        background: #fff;
        color: #000;
        border-radius: 100px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        font-size: 1.1rem;
    }

    .btn-cta-partners:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 40px rgba(56, 189, 248, 0.4);
        background: #38bdf8;
        color: #fff;
    }

    @media (max-width: 991px) {
        .benefits-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .partners-grid {
            grid-template-columns: 1fr;
            max-width: 500px;
        }

        .card-image {
            aspect-ratio: 16 / 9;
        }
    }
</style>
