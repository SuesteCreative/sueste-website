---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/Section.astro";

const partner = {
    name: "Nádine Campos",
    tagline: "photography & film production",
    logo: "/images/partners/SVG/logo-nadine-white.svg",
    bio: "Nádine Campos é uma fotógrafa e produtora cinematográfica de renome, reconhecida pela sua capacidade de captar a essência de cada momento através de uma lente artística e técnica. Com anos de experiência no setor, Nádine especializa-se em produções que contam histórias visuais poderosas, desde fotografia de produto e imobiliária a curtas metragens comerciais.",
    howWeWork:
        "A Sueste Creative e a Nádine Campos unem forças para oferecer soluções visuais integradas. Enquanto a Sueste foca na estratégia digital e design, a Nádine traz a magia da imagem real, garantindo que o conteúdo visual seja de classe mundial, elevando a percepção de marca dos nossos clientes.",
    images: [
        "https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&q=80&w=1200", // Photographer
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=1200", // Modern House
        "https://images.unsplash.com/photo-1473186578172-c141e679805a?auto=format&fit=crop&q=80&w=1200", // Interior Design
        "https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&q=80&w=1200", // Drone View
    ],
    pricing: {
        photo: {
            title: "Fotografia (c/ edição)",
            packs: [
                { name: "Pack 15", price: "45€", frames: "15 enquadramentos" },
                { name: "Pack 25", price: "65€", frames: "Até 120m²" },
                { name: "Pack 35", price: "90€", frames: "Até 200m²" },
                { name: "Pack 50", price: "115€", frames: "+250 m²" },
            ],
            addons: [
                { name: "Enquadramento extra", price: "3,50€ / un" },
                { name: "Retoque de imagem", price: "2,00€ a 25.00€" },
                { name: "Virtual staging", price: "2.00€ a 25.00€" },
                { name: "Retoque do céu", price: "5.00€" },
            ],
        },
        video: {
            title: "Vídeo (c/ edição)",
            packs: [
                { name: "Vídeo Standard", price: "120,00€", duration: "1 min" },
                { name: "Vídeo c/ Drone", price: "180,00€", duration: "2 min" },
                {
                    name: "Vídeo Reels",
                    price: "50,00€",
                    duration: "Extra 30 a 45 seg",
                },
            ],
            addons: [
                { name: "Minuto extra", price: "15€" },
                { name: "Títulos / Legendas", price: "2,00€ por layer" },
                { name: "Animação de logótipo", price: "5,00€" },
                { name: "Elementos gráficos", price: "2,00€ a 15,00€" },
            ],
        },
    },
};
---

<BaseLayout
    title={partner.name}
    description={`Saiba mais sobre a nossa parceria com ${partner.name}.`}
>
    <Navbar />

    <main class="partner-detail-page">
        <header class="partner-hero">
            <div class="container hero-inner">
                <div class="logo-reveal" data-reveal>
                    <img
                        src={partner.logo}
                        alt={partner.name}
                        class="partner-logo"
                    />
                </div>
                <h1 class="reveal-text" data-reveal>
                    <span class="partner-name-hero">{partner.name}</span>
                    <span class="partner-tagline-hero">{partner.tagline}</span>
                </h1>
                <div class="hero-line"></div>
            </div>
        </header>

        <Section id="bio" title="Sobre a Artista">
            <div class="bio-container grid">
                <div class="bio-text" data-reveal>
                    <p>{partner.bio}</p>
                </div>
                <div class="bio-image" data-reveal>
                    <img src={partner.images[0]} alt="Nádine Campos em ação" />
                </div>
            </div>
        </Section>

        <Section id="pricing" title="Serviços & Packs" dark>
            <div class="pricing-tabs">
                <div class="pricing-category">
                    <h3>{partner.pricing.photo.title}</h3>
                    <div class="packs-grid">
                        {
                            partner.pricing.photo.packs.map((pack) => (
                                <div class="pack-item glass">
                                    <span class="pack-name">{pack.name}</span>
                                    <span class="pack-price">{pack.price}</span>
                                    <span class="pack-detail">
                                        {pack.frames}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                    <ul class="addons-list">
                        {
                            partner.pricing.photo.addons.map((addon) => (
                                <li>
                                    <span class="addon-name">{addon.name}</span>
                                    <span class="addon-price">
                                        +{addon.price}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="pricing-category">
                    <h3>{partner.pricing.video.title}</h3>
                    <div class="packs-grid">
                        {
                            partner.pricing.video.packs.map((pack) => (
                                <div class="pack-item glass highlight">
                                    <span class="pack-name">{pack.name}</span>
                                    <span class="pack-price">{pack.price}</span>
                                    <span class="pack-detail">
                                        {pack.duration}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                    <ul class="addons-list">
                        {
                            partner.pricing.video.addons.map((addon) => (
                                <li>
                                    <span class="addon-name">{addon.name}</span>
                                    <span class="addon-price">
                                        +{addon.price}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </Section>

        <Section id="terms" title="Termos & Condições" dark>
            <div class="terms-grid">
                <div class="term-card" data-reveal>
                    <h4>Deslocação</h4>
                    <p>
                        Gratuito até 10km de Cascais. 0,50€/km para distâncias
                        superiores.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Revisões</h4>
                    <p>
                        1 revisão gratuita incluída. Alterações técnicas
                        orçamentadas separadamente.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Fidelidade</h4>
                    <p>
                        Desconto de 10% aplicado automaticamente na sua 5ª
                        marcação.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Entrega</h4>
                    <p>
                        Ficheiros entregues em formato digital. Armazenamento
                        garantido por 6 meses.
                    </p>
                </div>
            </div>
        </Section>

        <Section id="collaboration" title="Como Trabalhamos">
            <div class="collab-container">
                <div class="collab-content" data-reveal>
                    <div class="collab-card glass">
                        <div class="collab-icon">⚡</div>
                        <h3>Sinergia Estratégica</h3>
                        <p>{partner.howWeWork}</p>
                    </div>
                </div>
            </div>
        </Section>

        <Section id="cta" className="final-cta">
            <div class="cta-inner text-center">
                <h2>Pronto para elevar o seu projeto?</h2>
                <p>
                    Solicite um orçamento para combinar estes serviços com a
                    nossa estratégia digital.
                </p>
                <div style="margin-top: 3rem;">
                    <a href="/orcamento" class="btn-cta">Pedir Orçamento</a>
                </div>
            </div>
        </Section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .partner-detail-page {
        padding-top: 200px;
    }

    .partner-hero {
        min-height: 40vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .partner-logo {
        height: 150px;
        width: auto;
        border-radius: 20px;
        margin-bottom: 2rem;
    }

    .partner-name-hero {
        display: block;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .partner-tagline-hero {
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        color: #a1a1aa;
        letter-spacing: 0.1em;
    }

    .hero-line {
        width: 60px;
        height: 4px;
        background: #38bdf8;
        margin: 2rem auto 0;
    }

    .bio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .bio-text p {
        font-size: 1.2rem;
        line-height: 1.8;
        color: #a1a1aa;
    }

    .bio-image img {
        border-radius: 24px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .pricing-tabs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
    }

    .pricing-category h3 {
        font-size: 1.8rem;
        margin-bottom: 2rem;
        color: #fff;
        border-bottom: 2px solid rgba(56, 189, 248, 0.3);
        padding-bottom: 0.5rem;
        display: inline-block;
    }

    .packs-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .pack-item {
        padding: 1.5rem;
        border-radius: 20px;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .pack-item.highlight {
        border-color: rgba(56, 189, 248, 0.3);
        background: rgba(56, 189, 248, 0.02);
    }

    .pack-name {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .pack-price {
        font-size: 1.5rem;
        font-weight: 800;
        color: #38bdf8;
    }

    .pack-detail {
        font-size: 0.8rem;
        color: #71717a;
    }

    .addons-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .addons-list li {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .addon-name {
        font-weight: 500;
    }

    .addon-price {
        color: #38bdf8;
        font-weight: 700;
    }

    .collab-card {
        padding: 3rem;
        border-radius: 32px;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .terms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
    }

    .term-card {
        padding: 2rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 20px;
    }

    .term-card h4 {
        color: #38bdf8;
        margin-bottom: 1rem;
    }

    .btn-cta {
        display: inline-block;
        padding: 1.25rem 3rem;
        background: #fff;
        color: #000;
        border-radius: 100px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.3s ease;
    }

    .btn-cta:hover {
        transform: scale(1.05);
    }

    @media (max-width: 991px) {
        .pricing-tabs,
        .bio-container {
            grid-template-columns: 1fr;
        }
    }
</style>
