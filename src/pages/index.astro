---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HeroScrollSequence from "../components/HeroScrollSequence.astro";
import Section from "../components/Section.astro";
import PortfolioLanding from "../components/PortfolioLanding.astro";
import HeroPills from "../components/HeroPills.astro";
import { useTranslations } from "../utils/i18n";

const t = useTranslations("pt");
---

<BaseLayout title="Home" description={t("hero.subheadline")}>
  <Navbar isLandingPage={true} />

  <main>
    <HeroScrollSequence>
      <div class="hero-content container">
        <div class="hero-content-anim">
          <h1 set:html={t("hero.headline")}></h1>
          <HeroPills />
          <div
            style="display: flex; gap: 1rem; justify-content: center; margin-top: 2.5rem; flex-wrap: wrap;"
          >
            <a href="/servicos" class="btn-outline" style="min-width: 160px;"
              >Serviços</a
            >
            <a
              href="/orcamento"
              class="btn-cta"
              style="min-width: 160px; margin: 0;">Saber Mais</a
            >
          </div>
        </div>

        <div class="scroll-indicator">
          <span class="scroll-text">Faz scroll</span>
          <div class="mouse">
            <div class="wheel"></div>
          </div>
        </div>
      </div>
    </HeroScrollSequence>

    <Section
      id="services"
      title="Serviços"
      subtitle="Soluções criativas completas para levar a sua marca ao próximo nível."
      data-reveal
    >
      <div class="services-grid">
        <div class="service-card glass reveal-delay-1" data-reveal>
          <h3>Web Development</h3>
          <p>Websites rápidos, SEO-first e focados em conversão.</p>
        </div>
        <div class="service-card glass reveal-delay-2" data-reveal>
          <h3>Social Media</h3>
          <p>Gestão de redes sociais e criação de conteúdo estratégico.</p>
        </div>
        <div class="service-card glass reveal-delay-3" data-reveal>
          <h3>Drone Footage</h3>
          <p>Imagens aéreas cinematográficas em 4K para o seu negócio.</p>
        </div>
        <div class="service-card glass reveal-delay-1" data-reveal>
          <h3>Graphic Design</h3>
          <p>Identidade visual e design que comunica os seus valores.</p>
        </div>
      </div>
    </Section>

    <Section
      id="portfolio"
      title="Portfólio"
      subtitle="Projetos reais com resultados reais. Criatividade guiada por dados."
      data-reveal
    >
      <PortfolioLanding />
    </Section>

    <Section id="process" title="O Nosso Processo" dark data-reveal>
      <div class="process-steps">
        <div class="process-step reveal-delay-1" data-reveal>
          <span class="step-num">01</span>
          <h4>Discover</h4>
          <p>Analisamos os seus objetivos e o seu mercado.</p>
        </div>
        <div class="process-step reveal-delay-2" data-reveal>
          <span class="step-num">02</span>
          <h4>Design</h4>
          <p>Criamos a estratégia visual e funcional.</p>
        </div>
        <div class="process-step reveal-delay-3" data-reveal>
          <span class="step-num">03</span>
          <h4>Produce</h4>
          <p>Damos vida ao projeto com tecnologia de ponta.</p>
        </div>
        <div class="process-step reveal-delay-1" data-reveal>
          <span class="step-num">04</span>
          <h4>Deliver</h4>
          <p>Entregamos resultados mensuráveis.</p>
        </div>
      </div>
    </Section>

    <Section id="cta" className="final-cta" data-reveal>
      <div class="cta-box glass reveal-delay-1" data-reveal>
        <h2>Pronto para começar?</h2>
        <p>Peça um orçamento gratuito em menos de 2 minutos.</p>
        <a href="/orcamento" class="btn-cta">Pedir Orçamento</a>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-content {
    max-width: 900px;
    width: 100%;
  }

  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 4.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      rgba(255, 255, 255, 0.85) 40%,
      rgba(255, 255, 255, 0.3) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0px 8px 16px rgba(0, 0, 0, 0.4));
  }

  .hero-content p {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 3.5rem;
    font-weight: 300;
    line-height: 1.5;
    max-width: 85%;
    margin-left: auto;
    margin-right: auto;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
    display: none; /* Subheadline is hidden but style kept for safety */
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px 0 rgba(56, 189, 248, 0.3);
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(56, 189, 248, 0.5);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.05);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }

  .btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 6rem;
    opacity: 0.8;
  }

  .scroll-text {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .mouse {
    width: 26px;
    height: 40px;
    border-radius: 15px;
    border: 2px solid white;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .wheel {
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    animation: scroll-wheel 1.5s infinite;
  }

  @keyframes scroll-wheel {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .service-card {
    padding: 3rem 2rem;
    border-radius: 20px;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-10px);
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
  }

  .process-step {
    position: relative;
  }

  .step-num {
    font-size: 3rem;
    font-weight: 800;
    opacity: 0.1;
    display: block;
    margin-bottom: -1.5rem;
  }

  .process-step h4 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .final-cta {
    text-align: center;
  }

  .cta-box {
    padding: 6rem 2rem;
    border-radius: 40px;
  }

  .cta-box h2 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .cta-box p {
    margin-bottom: 3rem;
    font-size: 1.2rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.2rem;
    }
  }
</style>
