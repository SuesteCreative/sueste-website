---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HeroScrollSequence from "../components/HeroScrollSequence.astro";
import Section from "../components/Section.astro";
import PortfolioLanding from "../components/PortfolioLanding.astro";
import { useTranslations } from "../utils/i18n";

const t = useTranslations("pt");
---

<BaseLayout title="Home" description={t("hero.subheadline")}>
  <Navbar isLandingPage={true} />

  <main>
    <HeroScrollSequence>
      <div class="hero-content container">
        <h1>{t("hero.headline")}</h1>
        <p>{t("hero.subheadline")}</p>
        <div
          style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;"
        >
          <a href="/servicos" class="btn-outline" style="min-width: 160px;"
            >Serviços</a
          >
          <a
            href="/orcamento"
            class="btn-cta"
            style="min-width: 160px; margin: 0;">Orçamento</a
          >
        </div>
      </div>
    </HeroScrollSequence>

    <Section
      id="services"
      title="Serviços"
      subtitle="Soluções criativas completas para levar a sua marca ao próximo nível."
      data-reveal
    >
      <div class="services-grid">
        <div class="service-card glass reveal-delay-1" data-reveal>
          <h3>Web Development</h3>
          <p>Websites rápidos, SEO-first e focados em conversão.</p>
        </div>
        <div class="service-card glass reveal-delay-2" data-reveal>
          <h3>Social Media</h3>
          <p>Gestão de redes sociais e criação de conteúdo estratégico.</p>
        </div>
        <div class="service-card glass reveal-delay-3" data-reveal>
          <h3>Drone Footage</h3>
          <p>Imagens aéreas cinematográficas em 4K para o seu negócio.</p>
        </div>
        <div class="service-card glass reveal-delay-1" data-reveal>
          <h3>Graphic Design</h3>
          <p>Identidade visual e design que comunica os seus valores.</p>
        </div>
      </div>
    </Section>

    <Section
      id="portfolio"
      title="Portfólio"
      subtitle="Projetos reais com resultados reais. Criatividade guiada por dados."
      data-reveal
    >
      <PortfolioLanding />
    </Section>

    <Section id="process" title="O Nosso Processo" dark data-reveal>
      <div class="process-steps">
        <div class="process-step reveal-delay-1" data-reveal>
          <span class="step-num">01</span>
          <h4>Discover</h4>
          <p>Analisamos os seus objetivos e o seu mercado.</p>
        </div>
        <div class="process-step reveal-delay-2" data-reveal>
          <span class="step-num">02</span>
          <h4>Design</h4>
          <p>Criamos a estratégia visual e funcional.</p>
        </div>
        <div class="process-step reveal-delay-3" data-reveal>
          <span class="step-num">03</span>
          <h4>Produce</h4>
          <p>Damos vida ao projeto com tecnologia de ponta.</p>
        </div>
        <div class="process-step reveal-delay-1" data-reveal>
          <span class="step-num">04</span>
          <h4>Deliver</h4>
          <p>Entregamos resultados mensuráveis.</p>
        </div>
      </div>
    </Section>

    <Section id="cta" className="final-cta" data-reveal>
      <div class="cta-box glass reveal-delay-1" data-reveal>
        <h2>Pronto para começar?</h2>
        <p>Peça um orçamento gratuito em menos de 2 minutos.</p>
        <a href="/orcamento" class="btn-cta">Pedir Orçamento</a>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-content {
    max-width: 800px;
  }

  .hero-content h1 {
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 2rem;
    letter-spacing: -2px;
  }

  .hero-content p {
    font-size: 1.25rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }

  .btn-cta {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    transition: transform 0.3s ease;
  }

  .btn-cta:hover {
    transform: scale(1.05);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .service-card {
    padding: 3rem 2rem;
    border-radius: 20px;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-10px);
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
  }

  .process-step {
    position: relative;
  }

  .step-num {
    font-size: 3rem;
    font-weight: 800;
    opacity: 0.1;
    display: block;
    margin-bottom: -1.5rem;
  }

  .process-step h4 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .final-cta {
    text-align: center;
  }

  .cta-box {
    padding: 6rem 2rem;
    border-radius: 40px;
  }

  .cta-box h2 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .cta-box p {
    margin-bottom: 3rem;
    font-size: 1.2rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }
  }
</style>
