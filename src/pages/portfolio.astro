---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<BaseLayout
  title="Portfólio"
  description="Explore os projetos da Sueste Creative: e-commerce, sistemas de backoffice e sites de alta performance para empresas do Algarve e Portugal."
  hreflangPt="https://sueste-creative.pt/portfolio"
  hreflangEn="https://sueste-creative.pt/en/work"
>
  <Navbar />
  <main class="portfolio-page">
    <Section
      title="O Nosso Trabalho"
      subtitle="Uma seleção de projetos onde a criatividade encontra a estratégia."
    >
      <div class="p-grid">

        <a href="/portfolio/desportos-nauticos-alvor" class="pcard pc-1" style="--accent:#38bdf8">
          <img class="pcard-bg" src="/images/portfolio/desportos-mockup.png" alt="Mockup website Desportos Náuticos de Alvor" loading="lazy" />
          <div class="pcard-gradient"></div>
          <div class="pcard-content">
            <span class="pcard-cat">E-Commerce & Merch</span>
            <h3 class="pcard-title">Desportos Náuticos de Alvor</h3>
            <p class="pcard-desc">Sistema de reservas online e gestão de inventário para a maior escola de desportos náuticos do Algarve.</p>
            <span class="pcard-cta">Ver Projeto <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></span>
          </div>
          <span class="pcard-tag">Website</span>
        </a>

        <a href="/portfolio/mental8works" class="pcard pc-2" style="--accent:#a78bfa">
          <img class="pcard-bg" src="/images/portfolio/mental8works-mockup.png" alt="Plataforma Mental8Works mockup" loading="lazy" />
          <div class="pcard-gradient"></div>
          <div class="pcard-content">
            <span class="pcard-cat">Sys & Backoffice</span>
            <h3 class="pcard-title">Mental8Works</h3>
            <p class="pcard-desc">Plataforma de gestão de saúde mental corporativa com backoffice customizado e análise de dados em tempo real.</p>
            <span class="pcard-cta">Ver Projeto <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></span>
          </div>
          <span class="pcard-tag">Platform</span>
        </a>

        <a href="/portfolio/algo-atelier" class="pcard pc-3" style="--accent:#fbbf24">
          <img class="pcard-bg" src="/images/portfolio/algoatelier-mockup.png" alt="Portfólio Algo Atelier mockup" loading="lazy" />
          <div class="pcard-gradient"></div>
          <div class="pcard-content">
            <span class="pcard-cat">Architecture & SEO</span>
            <h3 class="pcard-title">Algo Atelier</h3>
            <p class="pcard-desc">Presença digital de alta performance para um atelier de arquitetura, focada em estética minimalista e SEO técnico.</p>
            <span class="pcard-cta">Ver Projeto <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></span>
          </div>
          <span class="pcard-tag">98% SEO</span>
        </a>

        <a href="/portfolio/desportos-nauticos-alvor" class="pcard pc-4" style="--accent:#22d3ee">
          <img class="pcard-bg" src="/images/portfolio/desportos-full.png" alt="Sistema CRM Desportos Náuticos de Alvor" loading="lazy" />
          <div class="pcard-gradient"></div>
          <div class="pcard-content">
            <span class="pcard-cat">CRM & Backoffice</span>
            <h3 class="pcard-title">DNA — CRM & Backoffice</h3>
            <p class="pcard-desc">Sistema de gestão interna com CRM personalizado, controlo de stocks e dashboards de performance em tempo real.</p>
            <span class="pcard-cta">Ver Projeto <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></span>
          </div>
          <span class="pcard-tag">Custom CRM</span>
        </a>

      </div>
    </Section>

    <Section
      title="O Nosso Método"
      subtitle="Como transformamos ideias em produtos de excelência."
      dark
    >
      <div class="process-steps">
        <div class="step" data-reveal>
          <div class="step-number">01</div>
          <h3>Descoberta</h3>
          <p>Imersão profunda no seu negócio para entender objetivos, audiência e desafios reais.</p>
        </div>
        <div class="step reveal-delay-1" data-reveal>
          <div class="step-number">02</div>
          <h3>Estratégia & Design</h3>
          <p>Planeamento estratégico e design focado na experiência intuitiva do utilizador.</p>
        </div>
        <div class="step reveal-delay-2" data-reveal>
          <div class="step-number">03</div>
          <h3>Desenvolvimento</h3>
          <p>Desenvolvimento de código de alta performance com as tecnologias mais recentes.</p>
        </div>
        <div class="step reveal-delay-3" data-reveal>
          <div class="step-number">04</div>
          <h3>Lançamento & Apoio</h3>
          <p>Entrega otimizada com suporte contínuo focado no crescimento do seu projeto.</p>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .portfolio-page {
    padding-top: 80px;
  }

  /* ── BENTO GRID ─────────────────────────────────────────────────── */
  .p-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: 500px 500px;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  .pc-1 { grid-column: 1 / 4; }
  .pc-2 { grid-column: 4 / 6; }
  .pc-3 { grid-column: 1 / 3; }
  .pc-4 { grid-column: 3 / 6; }

  /* ── CARD ───────────────────────────────────────────────────────── */
  .pcard {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.4s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pcard:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px -15px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .pcard-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pcard:hover .pcard-bg {
    transform: scale(1.05);
  }

  .pcard-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 5, 12, 0.96) 0%,
      rgba(5, 5, 12, 0.55) 40%,
      rgba(5, 5, 12, 0.1) 70%,
      transparent 100%
    );
  }

  .pcard-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pcard-cat {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    display: block;
  }

  .pcard-title {
    font-size: clamp(1.25rem, 2.5vw, 1.85rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .pcard-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.55;
    margin: 0.2rem 0 0;
  }

  .pcard-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .pcard:hover .pcard-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .pcard-tag {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    background: color-mix(in srgb, var(--accent) 12%, rgba(0, 0, 0, 0.5));
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    backdrop-filter: blur(10px);
    z-index: 2;
  }

  /* ── PROCESS ────────────────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 3rem;
    margin-top: 3rem;
  }

  .step {
    position: relative;
    padding-top: 2rem;
  }

  .step-number {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 1.5rem;
    opacity: 0.15;
    background: linear-gradient(135deg, white 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .step h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: white;
  }

  .step p {
    font-size: 1rem;
    opacity: 0.6;
    line-height: 1.6;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .p-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(2, 420px);
    }
    .pc-1 { grid-column: 1 / 2; }
    .pc-2 { grid-column: 2 / 3; }
    .pc-3 { grid-column: 1 / 2; }
    .pc-4 { grid-column: 2 / 3; }
  }

  @media (max-width: 640px) {
    .p-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, 360px);
      gap: 1rem;
    }
    .pc-1, .pc-2, .pc-3, .pc-4 { grid-column: 1 / 2; }
    .pcard-cta { opacity: 1; transform: none; }
    .process-steps { grid-template-columns: 1fr; gap: 4rem; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function init() {
    document.querySelectorAll(".pcard").forEach((card, i) => {
      gsap.fromTo(
        card,
        { opacity: 0, y: 40, scale: 0.97 },
        {
          opacity: 1, y: 0, scale: 1,
          duration: 0.9,
          ease: "power3.out",
          delay: (i % 2) * 0.1,
          scrollTrigger: { trigger: card, start: "top 88%" },
        }
      );
    });
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>
