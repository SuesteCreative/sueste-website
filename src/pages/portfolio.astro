---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<BaseLayout
  title="Portfólio"
  description="Veja os nossos projetos e casos de sucesso."
>
  <Navbar />
  <main class="portfolio-page">
    <Section
      title="O Nosso Trabalho"
      subtitle="Uma seleção de projetos onde a criatividade encontra a estratégia."
    >
      <div class="portfolio-grid">
        <a
          href="/portfolio/desportos-nauticos-alvor"
          class="portfolio-card glass"
          data-reveal
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1534440058864-4dccf1423cf9?auto=format&fit=crop&q=80&w=800'); background-size: cover; background-position: center;"
          >
            <div class="card-overlay"></div>
          </div>
          <div class="card-info">
            <span>E-Commerce & Merch</span>
            <h3>Desportos Náuticos de Alvor</h3>
            <p>
              Sistema de reservas online e gestão de inventário para a maior
              escola de desportos náuticos do Algarve.
            </p>
          </div>
        </a>

        <a
          href="/portfolio/mental8works"
          class="portfolio-card glass"
          data-reveal
          class="reveal-delay-2"
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800'); background-size: cover; background-position: center;"
          >
            <div class="card-overlay"></div>
          </div>
          <div class="card-info">
            <span>Sys & Backoffice</span>
            <h3>Mental8Works</h3>
            <p>
              Plataforma de gestão de saúde mental corporativa com backoffice
              customizado e análise de dados em tempo real.
            </p>
          </div>
        </a>

        <a
          href="/portfolio/algo-atelier"
          class="portfolio-card glass"
          data-reveal
          class="reveal-delay-3"
          style="grid-column: 1 / -1;"
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1600'); background-size: cover; background-position: center; height: 400px;"
          >
            <div class="card-overlay"></div>
          </div>
          <div
            class="card-info"
            style="display: flex; flex-direction: column; justify-content: flex-end; position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);"
          >
            <span>Architecture & SEO</span>
            <h3>Algo Atelier</h3>
            <p>
              Presença digital de alta performance para um atelier de
              arquitetura, focada em estética minimalista e SEO técnico.
            </p>
          </div>
        </a>
      </div>
    </Section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .portfolio-page {
    padding-top: 80px;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .portfolio-card {
    border-radius: 30px;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .portfolio-card:hover {
    transform: translateY(-15px) scale(1.02);
  }

  .card-image {
    height: 300px;
    background: linear-gradient(45deg, #111, #222);
    position: relative;
  }

  .card-info {
    padding: 2.5rem;
  }

  .card-info span {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: block;
  }

  .card-info h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .card-info p {
    opacity: 0.6;
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
