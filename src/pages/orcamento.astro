---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import BudgetCalculator from "../components/BudgetCalculator.tsx";
---

<BaseLayout
  title="Orçamento | Sueste Creative"
  description="Configure o seu projeto e obtenha uma estimativa imediata para serviços de web design, e-commerce e branding."
>
  <Navbar />

  <main class="quote-page">
    <Section
      title="Calculadora de Orçamento"
      subtitle="Personalize os serviços de que necessita e obtenha uma estimativa transparente em tempo real. Sem compromissos."
    >
      <BudgetCalculator client:load lang="pt" />
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .quote-page {
    padding-top: 120px;
    background: #09090b; /* Dark theme to match the glassmorphism */
    min-height: 100vh;
  }

  @media (max-width: 768px) {
    .quote-page {
      padding-top: 80px;
    }
  }
</style>
