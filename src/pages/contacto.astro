---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<BaseLayout
  title="Contacto"
  description="Fale com a Sueste Creative. Conte-nos o seu projeto e receba uma proposta personalizada em menos de 48 horas."
  hreflangPt="https://sueste-creative.pt/contacto"
  hreflangEn="https://sueste-creative.pt/en/contact"
>
  <Navbar />
  <main class="contact-page">
    <Section
      title="Vamos Conversar"
      subtitle="Traga a sua ideia e nós damos-lhe vida."
    >
      <div class="contact-grid">
        <div class="contact-info" data-reveal>
          <div class="info-item">
            <h4>E-mail</h4>
            <p>geral@sueste-creative.pt</p>
          </div>
          <div class="info-item">
            <h4>Localização</h4>
            <p>Lagos, Portugal</p>
          </div>
          <div class="info-item">
            <h4>Redes Sociais</h4>
            <div class="social-links">
              <a href="#">Instagram</a>
              <a href="#">LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="contact-form-wrapper glass reveal-delay-1" data-reveal>
          <form class="contact-form">
            <div class="form-group">
              <label for="name">Nome</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="O seu nome"
                required
              />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="o-seu@email.com"
                required
              />
            </div>
            <div class="form-group">
              <label for="message">Mensagem</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Como podemos ajudar?"
                required></textarea>
            </div>
            <button type="submit" class="btn-primary">Enviar Mensagem</button>
          </form>
        </div>
      </div>
    </Section>

    <Section
      title="Perguntas Frequentes"
      subtitle="Algumas das dúvidas mais comuns dos nossos clientes."
      dark
    >
      <div class="faq-container">
        <div class="faq-item glass" data-reveal>
          <button class="faq-trigger" aria-expanded="false">
            <h3>Quanto tempo demora um projeto?</h3>
            <div class="faq-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
              >
            </div>
          </button>
          <div class="faq-content">
            <div class="faq-content-inner">
              <p>
                Depende da complexidade. Um website institucional médio demora
                entre 3 a 6 semanas, enquanto um e-commerce ou sistema
                customizado pode levar 2 a 4 meses.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item glass reveal-delay-1" data-reveal>
          <button class="faq-trigger" aria-expanded="false">
            <h3>Trabalham com clientes internacionais?</h3>
            <div class="faq-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
              >
            </div>
          </button>
          <div class="faq-content">
            <div class="faq-content-inner">
              <p>
                Sim! Embora estejamos em Lagos, Portugal, trabalhamos com
                clientes de todo o mundo de forma 100% remota e eficiente.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item glass reveal-delay-2" data-reveal>
          <button class="faq-trigger" aria-expanded="false">
            <h3>Como funciona o processo de pagamento?</h3>
            <div class="faq-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
              >
            </div>
          </button>
          <div class="faq-content">
            <div class="faq-content-inner">
              <p>
                Normalmente dividimos o pagamento em 3 fases: adjudicação (50%),
                após aprovação do design (25%) e antes do lançamento (25%).
              </p>
            </div>
          </div>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-page {
    padding-top: 80px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }

  .info-item {
    margin-bottom: 2rem;
  }

  .info-item h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .info-item p {
    font-size: 1.2rem;
    opacity: 0.8;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .social-links a {
    font-size: 0.9rem;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .social-links a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .contact-form-wrapper {
    padding: 3rem;
    border-radius: 30px;
  }

  .form-group {
    margin-bottom: 2rem;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    opacity: 0.7;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: white;
    font-family: inherit;
    transition: border-color 0.3s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn-primary {
    width: 100%;
    padding: 1rem;
    border: none;
    cursor: pointer;
  }

  .faq-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .faq-item {
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .faq-item:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .faq-item.active {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: white;
  }

  .faq-trigger h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .faq-item:hover .faq-trigger h3 {
    color: var(--color-accent);
  }

  .faq-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .faq-icon svg {
    width: 18px;
    height: 18px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.active .faq-icon {
    background: var(--color-accent);
  }

  .faq-item.active .faq-icon svg {
    transform: rotate(180deg);
  }

  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.active .faq-content {
    grid-template-rows: 1fr;
  }

  .faq-content-inner {
    overflow: hidden;
  }

  .faq-content p {
    padding: 0 2rem 2rem 2rem;
    margin: 0;
    opacity: 0.7;
    line-height: 1.7;
    font-size: 1.05rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .contact-form-wrapper {
      padding: 2rem;
    }
    .faq-trigger {
      padding: 1.5rem;
    }
    .faq-trigger h3 {
      font-size: 1.1rem;
    }
    .faq-content p {
      padding: 0 1.5rem 1.5rem 1.5rem;
    }
  }
</style>

<script>
  function setupAccordion() {
    const items = document.querySelectorAll(".faq-item");

    items.forEach((item) => {
      const trigger = item.querySelector(".faq-trigger");
      if (!trigger) return;

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("active");

        // Close all other items
        items.forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.classList.remove("active");
            otherItem
              .querySelector(".faq-trigger")
              ?.setAttribute("aria-expanded", "false");
          }
        });

        // Toggle current item
        item.classList.toggle("active");
        trigger.setAttribute("aria-expanded", (!isOpen).toString());
      });
    });
  }

  // Initialize
  setupAccordion();

  // Handle Astro view transitions
  document.addEventListener("astro:after-swap", setupAccordion);
</script>
