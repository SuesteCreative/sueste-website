---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";
import Section from "../../../components/Section.astro";
---

<ProjectLayout
    title="Mental8Works"
    category="Sys & Backoffice"
    client="Mental8Works"
    year="2024"
    description="Corporate mental health management platform with custom backoffice and real-time data analysis."
    heroImage="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=1600"
    lang="en"
    metrics={[
        { label: "Active Users", value: "+8k" },
        { label: "Response Time", value: "-60%" },
        { label: "Satisfaction (NPS)", value: "9.2/10" },
    ]}
>
    <div class="container project-content-grid">
        <div class="project-text-block" data-reveal>
            <h2>The Challenge</h2>
            <p>
                Mental8Works required a tool capable of handling massive volumes
                of sensitive data while ensuring a fluid and empathetic user
                experience for both patients and therapists.
            </p>
            <p>
                The previous system was slow and fragmented, making it difficult
                to extract critical metrics for corporate HR departments.
            </p>
        </div>

        <div
            class="project-media project-media-right"
            data-reveal
            class="reveal-delay-1"
        >
            <img
                src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=1000"
                alt="Dashboard interface"
                class="rounded-xl glass-panel p-2"
            />
        </div>

        <div class="project-media project-media-left mt-16" data-reveal>
            <img
                src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=1000"
                alt="Data analytics view"
                class="rounded-xl glass-panel p-2"
            />
        </div>

        <div
            class="project-text-block mt-16"
            data-reveal
            class="reveal-delay-1"
        >
            <h2>The Solution</h2>
            <p>
                We engineered a <strong>Custom Backoffice</strong> that serves as
                the mission control for the operation. We focused on scalable data
                architecture and an intuitive dashboard design that prioritizes wellbeing
                indicator readability.
            </p>
            <ul>
                <li>Automated session and payment management.</li>
                <li>Business Intelligence module for real-time reporting.</li>
                <li>
                    Redundant infrastructure with a focus on data security
                    (GDPR).
                </li>
            </ul>
        </div>
    </div>
</ProjectLayout>

<style>
    .project-content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        margin-top: 4rem;
    }

    .project-text-block {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .project-text-block h2 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
    }

    .project-text-block h2::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: #38bdf8;
        border-radius: 2px;
    }

    .project-text-block p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.7);
    }

    .project-text-block ul {
        list-style-type: none;
        padding: 0;
        margin-top: 1rem;
    }

    .project-text-block li {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.8);
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .project-text-block li::before {
        content: "→";
        position: absolute;
        left: 0;
        color: #38bdf8;
        font-weight: bold;
    }

    .project-media img {
        width: 100%;
        height: auto;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .project-media:hover img {
        transform: scale(1.02);
    }

    @media (max-width: 900px) {
        .project-content-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }
</style>
