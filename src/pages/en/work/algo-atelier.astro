---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";
import Section from "../../../components/Section.astro";
---

<ProjectLayout
    title="Algo Atelier"
    category="Architecture"
    client="Algo Atelier"
    year="2025"
    description="High-performance digital presence for an architecture studio, focused on minimalist aesthetics and technical SEO."
    heroImage="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1600"
    lang="en"
    metrics={[
        { label: "SEO Score", value: "98/100" },
        { label: "Load Time", value: "0.8s" },
        { label: "Organic Visibility", value: "+150%" },
    ]}
>
    <div class="container project-content-grid">
        <div class="project-media project-media-left" data-reveal>
            <img
                src="https://images.unsplash.com/photo-1487958449913-22003c276326?auto=format&fit=crop&q=80&w=1000"
                alt="Minimalist architectural project"
                class="rounded-xl glass-panel p-2"
            />
        </div>

        <div class="project-text-block" data-reveal class="reveal-delay-1">
            <h2>Aesthetics & Performance</h2>
            <p>
                Algo Atelier is an architecture studio that values detail and
                the purity of forms. Their new website needed to reflect exactly
                that philosophy: to be invisible yet impactful.
            </p>
            <p>
                We worked on an "edge-to-edge" interface that puts architectural
                photography at the forefront, supported by a technical
                infrastructure that guarantees maximum scores in Google's Web
                Vitals.
            </p>
        </div>

        <div class="project-full-media mt-24 project-text-block" data-reveal>
            <h2>SEO as a Lever</h2>
            <p>
                More than a visual portfolio, we designed the content structure
                to dominate local and international searches for luxury
                architecture. Semantic optimization and response speed allowed
                us to achieve a 98% SEO score.
            </p>
        </div>

        <div
            class="project-media project-media-right"
            style="grid-column: 1 / -1; margin-top: 2rem;"
            data-reveal
        >
            <img
                src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1600"
                alt="Architectural structure detail"
                class="rounded-2xl glass-panel p-2 w-full"
            />
        </div>
    </div>
</ProjectLayout>

<style>
    .project-content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        margin-top: 4rem;
    }

    .project-text-block {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .project-text-block h2 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
    }

    .project-text-block h2::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: #38bdf8;
        border-radius: 2px;
    }

    .project-text-block p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.7);
    }

    .project-media img {
        width: 100%;
        height: auto;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .project-media:hover img {
        transform: scale(1.02);
    }

    .project-full-media {
        grid-column: 1 / -1;
    }

    @media (max-width: 900px) {
        .project-content-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .project-media-left {
            order: 1;
        }
    }
</style>
