---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';
import QuoteBuilder from '../../components/QuoteBuilder.jsx';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations('en');
---

<BaseLayout title="Quote" description="Configure your project and get an immediate estimate." lang="en">
  <Navbar />
  
  <main class="quote-page">
    <Section title="Quote Calculator" subtitle="Customize the services you need and get a transparent estimate in real time.">
      <QuoteBuilder client:load lang="en" />
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .quote-page {
    padding-top: 80px;
  }
</style>
