---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/Section.astro";
import BudgetCalculator from "../../components/BudgetCalculator.tsx";
---

<BaseLayout
  title="Quote | Sueste Creative"
  description="Configure your project and get an instant estimate for web design, e-commerce, and branding services."
>
  <Navbar />

  <main class="quote-page">
    <Section
      title="Budget Calculator"
      subtitle="Customize the services you need and get a clear, real-time estimate. No strings attached."
    >
      <BudgetCalculator client:load lang="en" />
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .quote-page {
    padding-top: 120px;
    background: #09090b;
    min-height: 100vh;
  }

  @media (max-width: 768px) {
    .quote-page {
      padding-top: 80px;
    }
  }
</style>
