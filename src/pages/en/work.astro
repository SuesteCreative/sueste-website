---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/Section.astro";
---

<BaseLayout
  title="Work"
  description="See our projects and success stories."
  lang="en"
>
  <Navbar />
  <main class="portfolio-page">
    <Section
      title="Our Work"
      subtitle="A selection of projects where creativity meets strategy."
    >
      <div class="portfolio-grid">
        <a
          href="/en/work/desportos-nauticos-alvor"
          class="portfolio-card glass"
          data-reveal
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1534440058864-4dccf1423cf9?auto=format&fit=crop&q=80&w=800'); background-size: cover; background-position: center;"
          >
            <div class="card-overlay"></div>
          </div>
          <div class="card-info">
            <span>E-Commerce & Merch</span>
            <h3>Desportos Náuticos de Alvor</h3>
            <p>
              Online booking system and inventory management for the largest
              nautical sports school in the Algarve.
            </p>
          </div>
        </a>

        <a
          href="/en/work/mental8works"
          class="portfolio-card glass reveal-delay-2"
          data-reveal
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800'); background-size: cover; background-position: center;"
          >
            <div class="card-overlay"></div>
          </div>
          <div class="card-info">
            <span>Sys & Backoffice</span>
            <h3>Mental8Works</h3>
            <p>
              Corporate mental health management platform with custom backoffice
              and real-time data analysis.
            </p>
          </div>
        </a>

        <a
          href="/en/work/algo-atelier"
          class="portfolio-card glass reveal-delay-3"
          data-reveal
          style="grid-column: 1 / -1;"
        >
          <div
            class="card-image"
            style="background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1600'); background-size: cover; background-position: center; height: 400px;"
          >
            <div class="card-overlay"></div>
          </div>
          <div
            class="card-info"
            style="display: flex; flex-direction: column; justify-content: flex-end; position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);"
          >
            <span>Architecture & SEO</span>
            <h3>Algo Atelier</h3>
            <p>
              High-performance digital presence for an architecture studio,
              focused on minimalist aesthetics and technical SEO.
            </p>
          </div>
        </a>
      </div>
    </Section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .portfolio-page {
    padding-top: 80px;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .portfolio-card {
    border-radius: 30px;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .portfolio-card:hover {
    transform: translateY(-15px) scale(1.02);
  }

  .card-image {
    height: 300px;
    background: linear-gradient(45deg, #111, #222);
    position: relative;
  }

  .card-info {
    padding: 2.5rem;
  }

  .card-info span {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: block;
  }

  .card-info h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .card-info p {
    opacity: 0.6;
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
