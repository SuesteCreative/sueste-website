---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Services"
  description="Websites, e-commerce, social media management, drone footage and SEO. Discover Sueste Creative's services and grow your digital presence."
  lang="en"
  hreflangPt="https://sueste-creative.pt/servicos"
  hreflangEn="https://sueste-creative.pt/en/services"
>
  <Navbar />
  <main class="services-page">
    <!-- HERO SECTION -->
    <header class="services-hero">
      <div class="container hero-inner">
        <h1 class="reveal-text">
          Digital Excellence <span class="highlight">in every pixel.</span>
        </h1>
        <p class="reveal-subtitle">
          Balancing aesthetics and functionality to create experiences that
          don't just stand out, but deliver measurable results.
        </p>
        <div class="hero-blobs">
          <div class="blob blob-1"></div>
          <div class="blob blob-2"></div>
        </div>
      </div>
    </header>

    <!-- DETAILED SERVICES WITH STICKY REVEAL -->
    <div class="services-showcase">
      {
        [
          {
            id: "web",
            title: "Web Development",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
            desc: "We build digital infrastructures that serve as the engine of your business. From code to conversion, every detail is optimized for extreme performance and a fluid user experience.",
            features: [
              {
                label: "Modern Stack",
                val: "Astro / React / Next.js",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
              },
              {
                label: "High Performance",
                val: "95+ LightHouse Scores",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
              },
              { label: "Native SEO", val: "Semantic Structure", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>` },
              {
                label: "Scalability",
                val: "Cloud Native Architecture",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
              },
            ],
            img: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=1600",
          },
          {
            id: "design",
            title: "Graphic Design & Branding",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 5 5"/><path d="m5.2 11.7 4.2 4.2"/></svg>`,
            desc: "Your visual identity is the first handshake with your client. We create coherent and memorable visual systems that communicate your values instantly and professionally.",
            features: [
              { label: "Branding", val: "Logos & Identity", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 5 5"/><path d="m5.2 11.7 4.2 4.2"/></svg>` },
              {
                label: "Print Media",
                val: "Editorial Design & Packaging",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
              },
              {
                label: "Digital Assets",
                val: "Ads & Social Graphics",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
              },
              {
                label: "UI Design",
                val: "Interface Prototyping",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
              },
            ],
            img: "https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&q=80&w=1600",
          },
          {
            id: "social",
            title: "Social Media Strategy",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
            desc: "Posting is the easy part. We build the strategy behind it — content that resonates with your audience, grows your community, and turns followers into clients.",
            features: [
              {
                label: "Content Creation",
                val: "Multi-format & Reels",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.06 11.9l8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1 1 2.48 1.02 3.5 1.02 1.68 0 3.02-1.34 3.02-3.02 0-1.67-1.36-3.04-3.02-3.04z"/></svg>`,
              },
              { label: "Community", val: "Active Management", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
              {
                label: "Paid Media",
                val: "Optimized Paid Traffic",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
              },
              { label: "Data Insights", val: "ROI Reports", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>` },
            ],
            img: "https://images.unsplash.com/photo-1611162617474-5b21e879e113?auto=format&fit=crop&q=80&w=1600",
          },
          {
            id: "video",
            title: "Drone & Cinematic Video",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"/><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-3"/></svg>`,
            desc: "Perspectives that change perception. We use cutting-edge technology to capture aerial and cinematic imagery that elevates your brand's perceived value and tells stories impossible to ignore.",
            features: [
              { label: "4K Aerial", val: "FPV Drone Capture", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>` },
              { label: "Cinematography", val: "Cinema Lenses", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>` },
              {
                label: "Color Grading",
                val: "Professional Looks",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>`,
              },
              {
                label: "Sound Design",
                val: "Immersive & Engaging",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
              },
            ],
            img: "/images/drone-footage.webp",
          },
        ].map((service, idx) => (
          <section
            class={`service-section ${idx % 2 !== 0 ? "reverse" : ""}`}
            id={service.id}
          >
            <div class="bg-number">0{idx + 1}</div>
            <div class="container grid-layout">
              <div class="service-content">
                <div class="service-header-with-icon">
                  <div class="service-icon-container" set:html={service.icon} />
                </div>
                <h2>{service.title}</h2>
                <p>{service.desc}</p>

                <div class="bento-features">
                  {service.features.map((f) => (
                    <div class="bento-item">
                      <span class="icon" set:html={f.icon}></span>
                      <div class="bento-text">
                        <span class="bento-label">{f.label}</span>
                        <span class="bento-val">{f.val}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="service-visual">
                <div class="image-reveal-wrapper">
                  <img
                    src={service.img}
                    alt={service.title}
                    class="reveal-image"
                  />
                  <div class="parallax-overlay">Sueste Creative</div>
                </div>
              </div>
            </div>
          </section>
        ))
      }
    </div>

    <!-- CENTRAL CTA -->
    <section class="services-final-cta">
      <div class="container text-center">
        <h2 class="cta-title">Ready to elevate your project?</h2>
        <p class="cta-desc">
          Let's transform your vision into reality with a results-oriented
          strategy.
        </p>
        <a href="/en/quote" class="btn-magnetic-v2">
          <span>Request a Quote Now</span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .services-page {
    background-color: #050505;
    color: #fff;
    overflow-x: hidden;
  }

  /* HERO */
  .services-hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 120px;
    /* Removed overflow: hidden to allow blobs to blend */
  }

  .hero-inner {
    position: relative;
    z-index: 10;
  }

  .services-hero h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    max-width: 900px;
  }

  .services-hero .highlight {
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .reveal-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: #a1a1aa;
    max-width: 650px;
    margin-top: 2rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .hero-blobs .blob {
    position: absolute;
    width: 400px;
    height: 400px;
    filter: blur(80px);
    border-radius: 50%;
    z-index: -1;
    opacity: 0.3;
  }

  .blob-1 {
    background: #38bdf8;
    top: 10%;
    right: -5%;
  }
  .blob-2 {
    background: #2563eb;
    bottom: -10%;
    left: -5%;
  }

  /* SERVICE SECTIONS */
  .service-section {
    padding: 12rem 0;
    position: relative;
    /* Removed border-bottom and overflow: hidden for a seamless look */
  }

  .bg-number {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    font-size: 50rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.1);
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
    line-height: 0.8;
    pointer-events: none;
    z-index: 0;
    transition: all 1s ease;
    letter-spacing: -0.05em;
  }

  .bg-number::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 45vw;
    height: 45vw;
    background: radial-gradient(
      circle,
      rgba(56, 189, 248, 0.15) 0%,
      transparent 70%
    );
    filter: blur(80px);
    z-index: -1;
    opacity: 0.8;
  }

  .reverse .bg-number {
    left: auto;
    right: 0;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 8rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .reverse .grid-layout {
    grid-template-columns: 1fr 1.2fr;
  }

  .reverse .service-content {
    grid-column: 2;
  }

  .reverse .service-visual {
    grid-column: 1;
    grid-row: 1;
  }

  .service-header-with-icon {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .service-icon-container {
    width: 4rem;
    height: 4rem;
    color: #38bdf8;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(56, 189, 248, 0.1);
    border-radius: 16px;
    padding: 1rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-icon-container :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-section:hover .service-icon-container {
    transform: scale(1.1) rotate(5deg);
    background: rgba(56, 189, 248, 0.2);
    box-shadow: 0 0 30px rgba(56, 189, 248, 0.2);
  }

  .service-content h2 {
    font-size: clamp(2.5rem, 4vw, 3.8rem);
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .service-content p {
    font-size: 1.25rem;
    color: #a1a1aa;
    line-height: 1.7;
    margin-bottom: 3.5rem;
    font-weight: 300;
  }

  /* BENTO FEATURES */
  .bento-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .bento-item {
    padding: 2rem;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(15, 15, 15, 0.6);
    backdrop-filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .bento-item:hover {
    border-color: #38bdf8;
    background: rgba(56, 189, 248, 0.08);
    transform: translateY(-5px);
    box-shadow: 0 0 30px rgba(56, 189, 248, 0.3);
  }

  /* Neon border highlight */
  .bento-item::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1px;
    background: linear-gradient(135deg, transparent, #38bdf8, transparent);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .bento-item:hover::after {
    opacity: 1;
  }

  .bento-item .icon {
    font-size: 2.5rem;
    transition: transform 0.4s ease;
  }

  .bento-item:hover .icon {
    transform: scale(1.1) rotate(5deg);
  }

  .bento-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bento-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
  }
  .bento-val {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    display: block;
    line-height: 1.2;
  }

  /* FINAL CTA */
  .services-final-cta {
    padding: 10rem 0;
    background: transparent;
    position: relative;
  }

  .text-center {
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
  }

  .cta-desc {
    font-size: 1.25rem;
    color: #a1a1aa;
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  /* BUTTON V2 */
  .btn-magnetic-v2 {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 3rem;
    background: #fff;
    border-radius: 100px;
    color: #000;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 10;
  }

  .btn-magnetic-v2:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 40px rgba(56, 189, 248, 0.5);
    background: #fff;
  }

  /* VISUALS */
  .service-visual {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
  }

  .image-reveal-wrapper {
    width: 100%;
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
  }

  .image-reveal-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.2);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .parallax-overlay {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.05);
    white-space: nowrap;
    pointer-events: none;
    line-height: 1;
  }

  @media (max-width: 1024px) {
    .bg-number {
      font-size: 30rem;
    }
    .grid-layout,
    .reverse .grid-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .service-visual,
    .reverse .service-visual {
      grid-column: 1;
      grid-row: auto;
      order: -1;
    }
    .reverse .service-content {
      grid-column: 1;
    }
    .bento-features {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Hero Animations
  const tl = gsap.timeline();
  tl.from(".reveal-text", {
    y: 100,
    opacity: 0,
    duration: 1.5,
    ease: "power4.out",
    delay: 0.2,
  }).from(
    ".reveal-subtitle",
    {
      y: 50,
      opacity: 0,
      duration: 1.2,
      ease: "power4.out",
    },
    "-=1",
  );

  // Floating blobs
  gsap.to(".blob-1", {
    x: 50,
    y: 100,
    duration: 20,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
  });
  gsap.to(".blob-2", {
    x: -80,
    y: -40,
    duration: 25,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
  });

  // Service Sections Reveal
  const sections = document.querySelectorAll(".service-section");
  sections.forEach((section) => {
    const img = section.querySelector(".reveal-image");
    const overlay = section.querySelector(".parallax-overlay");
    const icon = section.querySelector(".service-icon-container");
    const bgNumber = section.querySelector(".bg-number");

    // BG Number Parallax
    gsap.from(bgNumber, {
      x: -100,
      opacity: 0,
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
        end: "bottom 20%",
        scrub: true,
      },
    });

    // Image Zoom Parallax
    gsap.to(img, {
      scale: 1,
      scrollTrigger: {
        trigger: section,
        start: "top bottom",
        end: "bottom top",
        scrub: true,
      },
    });

    // Text Overlay Parallax
    gsap.to(overlay, {
      x: -50,
      scrollTrigger: {
        trigger: section,
        start: "top bottom",
        end: "bottom top",
        scrub: true,
      },
    });

    // Icon Pop
    gsap.from(icon, {
      scale: 0.5,
      opacity: 0,
      rotation: -45,
      duration: 1,
      ease: "back.out(1.7)",
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
      },
    });
  });

  // Final CTA Reveal
  gsap.from(".cta-title, .cta-desc, .services-final-cta .btn-magnetic-v2", {
    y: 50,
    opacity: 0,
    stagger: 0.2,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".services-final-cta",
      start: "top 95%",
    },
  });
</script>
