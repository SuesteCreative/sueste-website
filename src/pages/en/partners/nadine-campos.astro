---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import Section from "../../../components/Section.astro";

const partner = {
    name: "Nádine Campos photography & film production",
    logo: "/images/partners/logo-nadine-campos.jpeg",
    bio: "Nádine Campos is a renowned photographer and film producer, recognized for her ability to capture the essence of every moment through an artistic and technical lens. With years of experience in the industry, Nádine specializes in productions that tell powerful visual stories, from product photography to commercial short films.",
    howWeWork:
        "Sueste Creative and Nádine Campos join forces to offer integrated visual solutions. While Sueste focuses on digital strategy and design, Nádine brings the magic of reality-based imagery, ensuring that visual content is world-class, elevating our clients' brand perception.",
    images: [
        "https://images.unsplash.com/photo-1492691523567-6170e2415964?auto=format&fit=crop&q=80&w=800",
        "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=800",
        "https://images.unsplash.com/photo-1473186578172-c141e679805a?auto=format&fit=crop&q=80&w=800",
    ],
};
---

<BaseLayout
    title={partner.name}
    description={`Learn more about our partnership with ${partner.name}.`}
    lang="en"
>
    <Navbar />

    <main class="partner-detail-page">
        <header class="partner-hero">
            <div class="container hero-inner">
                <div class="logo-reveal" data-reveal>
                    <img
                        src={partner.logo}
                        alt={partner.name}
                        class="partner-logo"
                    />
                </div>
                <h1 class="reveal-text" data-reveal>{partner.name}</h1>
                <div class="hero-line"></div>
            </div>
        </header>

        <Section id="bio" title="About the Artist">
            <div class="bio-container grid">
                <div class="bio-text" data-reveal>
                    <p>{partner.bio}</p>
                </div>
                <div class="bio-image" data-reveal class="reveal-delay-1">
                    <img
                        src={partner.images[0]}
                        alt="Nádine Campos in action"
                    />
                </div>
            </div>
        </Section>

        <Section id="collaboration" title="How We Work" dark>
            <div class="collab-container">
                <div class="collab-content" data-reveal>
                    <div class="collab-card glass">
                        <div class="collab-icon">⚡</div>
                        <h3>Strategic Synergy</h3>
                        <p>{partner.howWeWork}</p>
                    </div>
                </div>
            </div>
        </Section>

        <Section id="gallery" title="Featured Portfolio">
            <div class="gallery-grid">
                {
                    partner.images.slice(1).map((img, idx) => (
                        <div
                            class="gallery-item"
                            data-reveal
                            class={`reveal-delay-${idx + 1}`}
                        >
                            <img src={img} alt={`Work by ${partner.name}`} />
                        </div>
                    ))
                }
            </div>
        </Section>

        <Section id="cta" className="final-cta">
            <div class="cta-inner text-center">
                <h2>Interested in this collaboration?</h2>
                <p>
                    Contact us to discuss how we can elevate your project
                    together.
                </p>
                <div style="margin-top: 3rem;">
                    <a href="/en/contact" class="btn-cta">Talk to the Team</a>
                </div>
            </div>
        </Section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .partner-detail-page {
        padding-top: 100px;
    }

    .partner-hero {
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: radial-gradient(
            circle at center,
            rgba(56, 189, 248, 0.1) 0%,
            transparent 70%
        );
    }

    .logo-reveal {
        margin-bottom: 3rem;
    }

    .partner-logo {
        height: 180px;
        width: auto;
        filter: brightness(1.1);
        border-radius: 20px;
    }

    .partner-hero h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 2rem;
    }

    .hero-line {
        width: 60px;
        height: 4px;
        background: #38bdf8;
        margin: 0 auto;
        border-radius: 2px;
    }

    .bio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .bio-text p {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #a1a1aa;
        font-weight: 300;
    }

    .bio-image img {
        border-radius: 30px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .collab-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .collab-card {
        padding: 4rem;
        border-radius: 40px;
        text-align: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .collab-icon {
        font-size: 4rem;
        margin-bottom: 2rem;
    }

    .collab-card h3 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
    }

    .collab-card p {
        font-size: 1.25rem;
        line-height: 1.7;
        color: #a1a1aa;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .gallery-item img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 20px;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        padding: 1.25rem 3rem;
        background: #fff;
        color: #000;
        border-radius: 100px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-cta:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 30px rgba(56, 189, 248, 0.4);
    }

    @media (max-width: 768px) {
        .bio-container,
        .gallery-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
