---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import Section from "../../../components/Section.astro";

const partner = {
    name: "Nádine Campos",
    tagline: "photography & film production",
    logo: "/images/partners/SVG/logo-nadine-white.svg",
    bio: "Nádine Campos is a renowned photographer and film producer, recognized for her ability to capture the essence of every moment through an artistic and technical lens. With years of experience in the industry, Nádine specializes in productions that tell powerful visual stories, from product and real estate photography to commercial short films.",
    howWeWork:
        "Sueste Creative and Nádine Campos join forces to offer integrated visual solutions. While Sueste focuses on digital strategy and design, Nádine brings the magic of reality-based imagery, ensuring that visual content is world-class, elevating our clients' brand perception.",
    images: [
        "https://images.unsplash.com/photo-1542038784456-1ea8e935640e?auto=format&fit=crop&q=80&w=1200", // Photographer
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=1200", // Modern House
        "https://images.unsplash.com/photo-1473186578172-c141e679805a?auto=format&fit=crop&q=80&w=1200", // Interior Design
        "https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&q=80&w=1200", // Drone View
    ],
    pricing: {
        photo: {
            title: "Photography (w/ editing)",
            packs: [
                { name: "Pack 15", price: "45€", frames: "Up to 90m²" },
                { name: "Pack 25", price: "65€", frames: "Up to 120m²" },
                { name: "Pack 35", price: "90€", frames: "Up to 200m²" },
                { name: "Pack 50", price: "115€", frames: "+250 m²" },
            ],
            addons: [
                { name: "Extra framing", price: "3.50€ / unit" },
                { name: "Image retouching", price: "2.00€ to 25.00€" },
                { name: "Virtual staging", price: "2.00€ to 25.00€" },
                { name: "Sky replacement", price: "5.00€" },
            ],
        },
        video: {
            title: "Video (w/ editing)",
            packs: [
                { name: "Standard Video", price: "120.00€", duration: "1 min" },
                { name: "Video w/ Drone", price: "180.00€", duration: "2 min" },
                {
                    name: "Reels Video",
                    price: "50.00€",
                    duration: "Extra 30 to 45 sec",
                },
            ],
            addons: [
                { name: "Extra minute", price: "15€" },
                { name: "Titles / Subtitles", price: "2.00€ per layer" },
                { name: "Logo animation", price: "5.00€" },
                { name: "Graphic elements", price: "2.00€ to 15.00€" },
            ],
        },
    },
};
---

<BaseLayout
    title={partner.name}
    description={`Learn more about our partnership with ${partner.name}.`}
    lang="en"
>
    <Navbar />

    <main class="partner-detail-page">
        <header class="partner-hero">
            <div class="container hero-inner">
                <div class="logo-reveal" data-reveal>
                    <img
                        src={partner.logo}
                        alt={partner.name}
                        class="partner-logo"
                    />
                </div>
                <h1 class="reveal-text" data-reveal>
                    <span class="partner-name-hero">{partner.name}</span>
                    <span class="partner-tagline-hero">{partner.tagline}</span>
                </h1>
                <div class="hero-line"></div>
            </div>
        </header>

        <Section id="bio" title="About the Artist">
            <div class="bio-container grid">
                <div class="bio-text" data-reveal>
                    <p>{partner.bio}</p>
                </div>
                <div class="bio-image" data-reveal>
                    <img
                        src={partner.images[0]}
                        alt="Nádine Campos in action"
                    />
                </div>
            </div>
        </Section>

        <Section id="pricing" title="Services & Packs" dark>
            <div class="pricing-tabs">
                <div class="pricing-category">
                    <h3>{partner.pricing.photo.title}</h3>
                    <div class="packs-grid">
                        {
                            partner.pricing.photo.packs.map((pack) => (
                                <div class="pack-item glass">
                                    <span class="pack-name">{pack.name}</span>
                                    <span class="pack-price">{pack.price}</span>
                                    <span class="pack-detail">
                                        {pack.frames}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                    <ul class="addons-list">
                        {
                            partner.pricing.photo.addons.map((addon) => (
                                <li>
                                    <span class="addon-name">{addon.name}</span>
                                    <span class="addon-price">
                                        +{addon.price}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="pricing-category">
                    <h3>{partner.pricing.video.title}</h3>
                    <div class="packs-grid">
                        {
                            partner.pricing.video.packs.map((pack, idx) => (
                                <div
                                    class={`pack-item glass highlight ${idx === 2 ? "span-full" : ""}`}
                                >
                                    <span class="pack-name">{pack.name}</span>
                                    <span class="pack-price">{pack.price}</span>
                                    <span class="pack-detail">
                                        {pack.duration}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                    <ul class="addons-list">
                        {
                            partner.pricing.video.addons.map((addon) => (
                                <li>
                                    <span class="addon-name">{addon.name}</span>
                                    <span class="addon-price">
                                        +{addon.price}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </Section>

        <Section id="terms" title="Terms & Conditions" dark>
            <div class="terms-grid">
                <div class="term-card" data-reveal>
                    <h4>Travel</h4>
                    <p>
                        Free within 15km. Beyond this limit, a 0.30€/km fee
                        (round trip) and applicable tolls apply.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Revisions</h4>
                    <p>
                        1 free revision included. Extra technical changes quoted
                        separately.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Loyalty</h4>
                    <p>
                        Special 10% discount automatically applied starting from
                        your 5th appointment with us.
                    </p>
                </div>
                <div class="term-card" data-reveal>
                    <h4>Delivery</h4>
                    <p>
                        Files delivered in digital format with guaranteed
                        storage for 6 months.
                    </p>
                </div>
            </div>
        </Section>

        <Section id="collaboration" title="How We Work">
            <div class="collab-container">
                <div class="collab-content" data-reveal>
                    <div class="collab-card glass">
                        <div class="collab-icon">⚡</div>
                        <h3>Strategic Synergy</h3>
                        <p>{partner.howWeWork}</p>
                    </div>
                </div>
            </div>
        </Section>

        <Section id="cta" className="final-cta">
            <div class="cta-inner text-center">
                <h2>Ready to elevate your project?</h2>
                <p>
                    Request a quote to combine these services with our digital
                    strategy.
                </p>
                <div style="margin-top: 3rem;">
                    <a href="/en/quote" class="btn-cta">Request Quote</a>
                </div>
            </div>
        </Section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .partner-detail-page {
        padding-top: 200px;
    }

    .partner-hero {
        min-height: 40vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .partner-logo {
        height: 150px;
        width: auto;
        border-radius: 20px;
        margin-bottom: 2rem;
    }

    .partner-name-hero {
        display: block;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .partner-tagline-hero {
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        color: #a1a1aa;
        letter-spacing: 0.1em;
    }

    .hero-line {
        width: 60px;
        height: 4px;
        background: #38bdf8;
        margin: 2rem auto 0;
    }

    .bio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .bio-text p {
        font-size: 1.2rem;
        line-height: 1.8;
        color: #a1a1aa;
    }

    .bio-image img {
        border-radius: 24px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .pricing-tabs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
    }

    .pricing-category h3 {
        font-size: 1.8rem;
        margin-bottom: 2rem;
        color: #fff;
        border-bottom: 2px solid rgba(56, 189, 248, 0.3);
        padding-bottom: 0.5rem;
        display: inline-block;
    }

    .packs-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .pack-item {
        padding: 1.5rem;
        border-radius: 20px;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .pack-item.highlight {
        border-color: rgba(56, 189, 248, 0.3);
        background: rgba(56, 189, 248, 0.02);
    }

    .pack-name {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .pack-price {
        font-size: 1.5rem;
        font-weight: 800;
        color: #38bdf8;
    }

    .pack-detail {
        font-size: 0.8rem;
        color: #71717a;
    }

    .addons-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .addons-list li {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .addon-name {
        font-weight: 500;
    }

    .addon-price {
        color: #38bdf8;
        font-weight: 700;
    }

    .collab-card {
        padding: 3rem;
        border-radius: 32px;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .terms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
    }

    .term-card {
        padding: 2.25rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.04);
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .span-full {
        grid-column: span 2;
    }

    @media (max-width: 768px) {
        .span-full {
            grid-column: span 1;
        }
    }

    .term-card h4 {
        color: #38bdf8;
        margin-bottom: 1rem;
    }

    .btn-cta {
        display: inline-block;
        padding: 1.25rem 3rem;
        background: #fff;
        color: #000;
        border-radius: 100px;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.3s ease;
    }

    .btn-cta:hover {
        transform: scale(1.05);
    }

    @media (max-width: 991px) {
        .pricing-tabs,
        .bio-container {
            grid-template-columns: 1fr;
        }
    }
</style>
