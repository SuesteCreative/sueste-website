---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import Section from "../../../components/Section.astro";

const partner = {
    name: "Nádine Campos",
    tagline: "photography & film production",
    logo: "/images/partners/logo-nadine-campos.jpeg",
    bio: "Nádine Campos is a renowned photographer and film producer, recognized for her ability to capture the essence of every moment through an artistic and technical lens. With years of experience in the industry, Nádine specializes in productions that tell powerful visual stories, from real estate and product photography to commercial short films.",
    howWeWork:
        "Sueste Creative and Nádine Campos join forces to offer integrated visual solutions. While Sueste focuses on digital strategy and design, Nádine brings the magic of reality-based imagery, ensuring that visual content is world-class, elevating our clients' brand perception.",
    images: [
        "https://images.unsplash.com/photo-1554048612-b6a482bc67e5?auto=format&fit=crop&q=80&w=1200",
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=1200",
        "https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&q=80&w=1200",
        "https://images.unsplash.com/photo-1473186578172-c141e679805a?auto=format&fit=crop&q=80&w=1200",
    ],
};
---

<BaseLayout
    title={partner.name}
    description={`Learn more about our partnership with ${partner.name}.`}
    lang="en"
>
    <Navbar />

    <main class="partner-detail-page">
        <header class="partner-hero">
            <div class="container hero-inner">
                <div class="logo-reveal" data-reveal>
                    <img
                        src={partner.logo}
                        alt={partner.name}
                        class="partner-logo"
                    />
                </div>
                <h1 class="reveal-text" data-reveal>
                    <span class="partner-name-hero">{partner.name}</span>
                    <span class="partner-tagline-hero">{partner.tagline}</span>
                </h1>
                <div class="hero-line"></div>
            </div>
        </header>

        <Section id="bio" title="About the Artist">
            <div class="bio-container grid">
                <div class="bio-text" data-reveal>
                    <p>{partner.bio}</p>
                </div>
                <div class="bio-image" data-reveal class="reveal-delay-1">
                    <img
                        src={partner.images[0]}
                        alt="Professional photographer in action"
                    />
                </div>
            </div>
        </Section>

        <Section id="collaboration" title="How We Work" dark>
            <div class="collab-container">
                <div class="collab-content" data-reveal>
                    <div class="collab-card glass">
                        <div class="collab-icon">⚡</div>
                        <h3>Strategic Synergy</h3>
                        <p>{partner.howWeWork}</p>
                    </div>
                </div>
            </div>
        </Section>

        <Section id="gallery" title="Featured Portfolio">
            <div class="gallery-grid">
                {
                    partner.images.slice(1).map((img, idx) => (
                        <div
                            class="gallery-item"
                            data-reveal
                            class={`reveal-delay-${idx + 1}`}
                        >
                            <img src={img} alt={`Work by ${partner.name}`} />
                        </div>
                    ))
                }
            </div>
        </Section>

        <Section id="terms" title="Terms & Conditions" dark>
            <div class="terms-grid">
                <div class="term-card" data-reveal>
                    <h4>Travel</h4>
                    <p>
                        Free within a 10km radius of Cascais. 0.50€/km for
                        additional distances.
                    </p>
                </div>
                <div class="term-card" data-reveal class="reveal-delay-1">
                    <h4>Revisions</h4>
                    <p>
                        1 free revision included. Extra changes quoted at
                        15.00€/hour.
                    </p>
                </div>
                <div class="term-card" data-reveal class="reveal-delay-2">
                    <h4>Loyalty</h4>
                    <p>
                        10% discount automatically applied on your 5th
                        appointment.
                    </p>
                </div>
                <div class="term-card" data-reveal class="reveal-delay-3">
                    <h4>Deadlines & Archive</h4>
                    <p>Fast file delivery. Guaranteed storage for 6 months.</p>
                </div>
            </div>
        </Section>

        <Section id="cta" className="final-cta">
            <div class="cta-inner text-center">
                <h2>Ready to elevate your project?</h2>
                <p>Request a custom quote for your next visual project.</p>
                <div style="margin-top: 3rem;">
                    <a href="/en/quote" class="btn-cta">Request Quote</a>
                </div>
            </div>
        </Section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .partner-detail-page {
        padding-top: 100px;
    }

    .partner-hero {
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: radial-gradient(
            circle at center,
            rgba(56, 189, 248, 0.1) 0%,
            transparent 70%
        );
    }

    .logo-reveal {
        margin-bottom: 3rem;
    }

    .partner-logo {
        height: 180px;
        width: auto;
        filter: brightness(1.1);
        border-radius: 20px;
    }

    .partner-hero h1 {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .partner-name-hero {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        line-height: 1.1;
    }

    .partner-tagline-hero {
        font-size: clamp(1.1rem, 2vw, 1.5rem);
        font-weight: 300;
        font-style: italic;
        color: #a1a1aa;
        letter-spacing: 0.1em;
    }

    .hero-line {
        width: 60px;
        height: 4px;
        background: #38bdf8;
        margin: 2rem auto 0;
        border-radius: 2px;
    }

    .bio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .bio-text p {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #a1a1aa;
        font-weight: 300;
    }

    .bio-image img {
        border-radius: 30px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .collab-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .collab-card {
        padding: 4rem;
        border-radius: 40px;
        text-align: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .collab-icon {
        font-size: 4rem;
        margin-bottom: 2rem;
    }

    .collab-card h3 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
    }

    .collab-card p {
        font-size: 1.25rem;
        line-height: 1.7;
        color: #a1a1aa;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .gallery-item img {
        width: 100%;
        aspect-ratio: 4/5;
        object-fit: cover;
        border-radius: 20px;
        transition: transform 0.5s ease;
    }

    .gallery-item:hover img {
        transform: scale(1.05);
    }

    .terms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
    }

    .term-card {
        padding: 2.5rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        transition: background 0.3s ease;
    }

    .term-card:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .term-card h4 {
        color: #38bdf8;
        font-size: 1.2rem;
        margin-bottom: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .term-card p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #a1a1aa;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        padding: 1.25rem 3rem;
        background: #fff;
        color: #000;
        border-radius: 100px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-cta:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 30px rgba(56, 189, 248, 0.4);
    }

    @media (max-width: 991px) {
        .gallery-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 768px) {
        .bio-container,
        .gallery-grid,
        .terms-grid {
            grid-template-columns: 1fr;
        }

        .partner-hero {
            min-height: 40vh;
        }
    }
</style>
