---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import HeroScrollSequence from "../../components/HeroScrollSequence.astro";
import WhoWeAre from "../../components/WhoWeAre.astro";
import Section from "../../components/Section.astro";
import PortfolioLanding from "../../components/PortfolioLanding.astro";
import BentoServices from "../../components/BentoServices.astro";
import ProcessHorizontalScroll from "../../components/ProcessHorizontalScroll.astro";
import Testimonials from "../../components/Testimonials.astro";
import HeroPills from "../../components/HeroPills.astro";
import { useTranslations } from "../../utils/i18n";

const lang = "en"; // Keeping 'en' as the CTA text and overall context is English.
const t = useTranslations(lang);
---

<BaseLayout title="Home" description={t("hero.subheadline")} lang="en">
  <Navbar isLandingPage={true} />

  <main>
    <HeroScrollSequence>
      <div class="hero-content container">
        <div class="hero-content-anim">
          <h1 set:html={t("hero.headline")}></h1>
          <HeroPills />
          <div
            style="display: flex; gap: 1rem; justify-content: center; margin-top: 2.5rem; flex-wrap: wrap;"
          >
            <a href="/en/services" class="btn-outline" style="min-width: 160px;"
              >Services</a
            >
            <a
              href="/en/quote"
              class="btn-cta"
              style="min-width: 160px; margin: 0;">Learn More</a
            >
          </div>
        </div>

        <div class="scroll-indicator">
          <span class="scroll-text">Scroll down</span>
          <div class="mouse">
            <div class="wheel"></div>
          </div>
        </div>
      </div>
    </HeroScrollSequence>

    <WhoWeAre lang="en" />

    <Section
      id="services"
      title="Services"
      subtitle="Complete creative solutions to take your brand to the next level."
      data-reveal
    >
      <BentoServices lang="en" />
    </Section>

    <Section
      id="portfolio"
      title="Portfolio"
      subtitle="Real projects with real results. Data-driven creativity."
      data-reveal
    >
      <PortfolioLanding lang="en" />
    </Section>

    <Section id="process" title="" dark data-reveal>
      <ProcessHorizontalScroll lang="en" />
    </Section>

    <Testimonials lang="en" />

    <Section id="cta" className="final-cta-new">
      <div class="cta-container-v2">
        <div class="cta-massive-text" id="cta-reveal-text">
          <div class="cta-line">
            <span class="word">READY</span>
          </div>
          <div class="cta-line">
            <span class="word">TO</span>
          </div>
          <div class="cta-line">
            <span class="word highlight">START?</span>
          </div>
        </div>

        <div class="cta-footer-v2">
          <p class="cta-desc-v2">
            Transform your vision into an elite digital presence. Our team is
            ready to create the customized solution your business deserves.
          </p>
          <a href="/en/quote" class="btn-cta-v2">
            <span>Request Quote Now</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
                points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-content {
    max-width: 900px;
    width: 100%;
  }

  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 4.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      rgba(255, 255, 255, 0.85) 40%,
      rgba(255, 255, 255, 0.3) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0px 8px 16px rgba(0, 0, 0, 0.4));
  }

  .hero-content p {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 3.5rem;
    font-weight: 300;
    line-height: 1.5;
    max-width: 85%;
    margin-left: auto;
    margin-right: auto;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
    display: none; /* Subheadline is hidden but style kept for safety */
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px 0 rgba(56, 189, 248, 0.3);
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(56, 189, 248, 0.5);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.05);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }

  .btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 6rem;
    opacity: 0.8;
  }

  .scroll-text {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .mouse {
    width: 26px;
    height: 40px;
    border-radius: 15px;
    border: 2px solid white;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .wheel {
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background: white;
    animation: scroll-wheel 1.5s infinite;
  }

  @keyframes scroll-wheel {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .service-card {
    padding: 3rem 2rem;
    border-radius: 20px;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-10px);
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
  }

  .process-step {
    position: relative;
  }

  .step-num {
    font-size: 3rem;
    font-weight: 800;
    opacity: 0.1;
    display: block;
    margin-bottom: -1.5rem;
  }

  .process-step h4 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .final-cta-new {
    padding: 10rem 0;
    background: transparent;
    overflow: hidden;
  }

  .cta-container-v2 {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  .cta-massive-text {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-line {
    overflow: hidden;
    height: auto;
    margin: -1rem 0;
    display: flex;
    justify-content: center;
  }

  .cta-massive-text .word {
    font-size: clamp(4rem, 15vw, 13rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    display: inline-block;
    background: linear-gradient(180deg, #fff 0%, #333 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transform: translateY(105%); /* Hidden initially */
  }

  .cta-massive-text .word.highlight {
    background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .cta-footer-v2 {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    opacity: 0;
    transform: translateY(30px);
  }

  .cta-desc-v2 {
    font-size: 1.25rem;
    color: #a1a1aa;
    line-height: 1.6;
    text-align: center;
    font-weight: 300;
  }

  .btn-cta-v2 {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 3rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .btn-cta-v2:before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.05),
      transparent
    );
    transition: left 0.6s ease;
  }

  .btn-cta-v2:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
    transform: scale(1.05);
  }

  .btn-cta-v2:hover:before {
    left: 100%;
  }

  .btn-cta-v2 svg {
    transition: transform 0.4s ease;
  }

  .btn-cta-v2:hover svg {
    transform: translate(3px, -3px);
  }

  @media (max-width: 768px) {
    .cta-line {
      margin: -0.5rem 0;
    }
    .cta-container-v2 {
      gap: 2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function setupInteractiveCTA() {
    const section = document.querySelector(".final-cta-new");
    const words = document.querySelectorAll(".cta-massive-text .word");
    const footer = document.querySelector(".cta-footer-v2");

    if (!section || words.length === 0) return;

    // Reveal Animation inspired by Studio Ardé
    gsap.to(words, {
      y: 0,
      duration: 1.5,
      stagger: 0.15,
      ease: "power4.out",
      scrollTrigger: {
        trigger: section,
        start: "top 70%",
      },
    });

    gsap.to(footer, {
      opacity: 1,
      y: 0,
      duration: 1,
      delay: 0.8,
      ease: "power3.out",
      scrollTrigger: {
        trigger: section,
        start: "top 70%",
      },
    });

    // Magnetic Button Effect
    const btn = document.querySelector(".btn-cta-v2") as HTMLElement;
    if (btn) {
      btn.addEventListener("mousemove", (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        gsap.to(btn, {
          x: x * 0.3,
          y: y * 0.3,
          duration: 0.4,
          ease: "power2.out",
        });

        const innerSpan = btn.querySelector("span");
        if (innerSpan) {
          gsap.to(innerSpan, {
            x: x * 0.2,
            y: y * 0.2,
            duration: 0.4,
            ease: "power2.out",
          });
        }
      });

      btn.addEventListener("mouseleave", () => {
        gsap.to(btn, { x: 0, y: 0, duration: 1, ease: "elastic.out(1, 0.4)" });
        const innerSpan = btn.querySelector("span");
        if (innerSpan)
          gsap.to(innerSpan, {
            x: 0,
            y: 0,
            duration: 1,
            ease: "elastic.out(1, 0.4)",
          });
      });
    }
  }

  setupInteractiveCTA();
  document.addEventListener("astro:after-swap", setupInteractiveCTA);
</script>
